def resolve_xcode_version():
    """Returns the short Xcode version (e.g. `"16.2"`) or None. Tries
    `$XCODE_VERSION_ACTUAL` first (set in every Run Script env —
    numeric like `1620`, needs reformatting), then falls back to
    `xcodebuild -version` which is slow but ground-truth.

    Prefers `bugsee-cli build-env xcode-version` when available
    (single cross-language source of truth, ported from this
    Python implementation — see `bugsee-cli/src/cli/build_env.rs`).
    Falls back to the in-process Python below when the CLI isn't
    installed."""
    via_cli = _resolve_xcode_version_via_cli()
    if via_cli is not None:
        return via_cli

    actual = os.environ.get('XCODE_VERSION_ACTUAL')
    if actual and actual.isdigit():
        # "1620" → "16.2.0" ; "1543" → "15.4.3"
        parts = [actual[0:-2] or '0', actual[-2:-1] or '0',
                 actual[-1:] or '0']
        return '.'.join(p.lstrip('0') or '0' for p in parts)

    try:
        result = subprocess.run(
            ['/usr/bin/xcodebuild', '-version'],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            return None
        first_line = ((result.stdout or '').splitlines()[0].strip()
                      if result.stdout else '')
        m = re.match(r'^Xcode\s+(\S+)', first_line)
        return m.group(1) if m else None
    except Exception:
        return None


# ──────────────────────────────────────────────────────────────────
# Xcode env + Info.plist helpers
# ──────────────────────────────────────────────────────────────────

def _read_info_plist_via_cli(plist_path):
    """Shell to `bugsee-cli build-env read-plist <path>` and parse
    the JSON. Option-C migration target."""
    if not plist_path:
        return None
    cli_path_opt = None
    cli_version_opt = None
    try:
        cli_path_opt = getattr(options, 'cli_path', None)
        cli_version_opt = getattr(options, 'cli_version', None)
    except NameError:
        pass
    cli = resolveCli(cli_path_opt, cli_version_opt)
    if not cli:
        return None
    try:
        result = subprocess.run(
            [cli, "build-env", "read-plist", plist_path],
            capture_output=True, text=True, timeout=10, check=False,
        )
        if result.returncode != 0:
            return None
        out = (result.stdout or "").strip()
        if not out:
            return None
        return json.loads(out)
    except _CLI_CATCHALL_EXCEPTIONS:
        return None


def _read_info_plist(plist_path):
    """Read the binary or XML Info.plist at the given path. Returns
    a dict on success or `{}` on any error — the caller treats
    missing fields as best-effort and falls back to env vars.

    Prefers `bugsee-cli build-env read-plist` when available
    (single cross-language source of truth). Falls back to the
    in-process `plistlib.load` below.

    Choke-point dict-coercion: every caller (`_collect_build_metadata`,
    `resolve_bundle_info_from_app`, `_extract_uuid_from_app`, …)
    indexes the return value as a dict. The CLI's `read-plist`
    returns whatever `json.loads(stdout)` produces with no shape
    validation, so a future CLI bug, version-skew, or exotic plist
    could surface as a list/string/number and crash every call site
    with `AttributeError`. Coerce non-dict returns to `{}` HERE so
    no caller needs its own isinstance guard."""
    via_cli = _read_info_plist_via_cli(plist_path)
    if via_cli is not None:
        return via_cli if isinstance(via_cli, dict) else {}

    if not plist_path or not os.path.isfile(plist_path):
        return {}
    try:
        with open(plist_path, 'rb') as f:
            data = plistlib.load(f)
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def resolve_bundle_info_from_app(app_path):
    """Read the Info.plist inside a `.app` bundle and return
    `(bundle_id, version, build)`. Any field may be None when the
    plist lacks it or can't be read.

    Mirrors the SDK BugseeAgent's
    `tools.bundle/BugseeAgent::resolve_bundle_info_from_app` so the
    fastlane artefact-upload flow ships the SAME baseline-lookup
    keys (`package_id`, `version`, `build`) the SDK does. Without
    matching keys the back-end's `/builds/baseline` lookup never
    finds a previous build for the same package, and the dashboard's
    size-trend chart silently shows no delta.
    """
    if not app_path or not os.path.isdir(app_path):
        return (None, None, None)
    plist_path = os.path.join(app_path, 'Info.plist')
    # `_read_info_plist` coerces non-dict CLI returns to `{}` at the
    # choke point, so an unguarded `.get()` is safe here.
    info = _read_info_plist(plist_path)
    return (
        info.get('CFBundleIdentifier'),
        info.get('CFBundleShortVersionString'),
        info.get('CFBundleVersion'),
    )


# Arch preference order for fat-binary LC_UUID selection. arm64 wins
# because it's the slice the runtime SDK reports on actual device
# crashes; arm64e is M-series Macs; x86_64 covers Intel macs; the
# simulator variants come last (only useful for simulator-only Debug
# Build configs). Matches the SDK BugseeAgent's
# `tools.bundle/BugseeAgent::_PREFERRED_MACHO_ARCHS` ordering exactly
# so the fastlane and SDK producers emit the SAME uuid for the same
# fat-binary build.
_PREFERRED_MACHO_ARCHS = ('arm64', 'arm64e', 'x86_64',
                         'arm64-simulator', 'x86_64-simulator')


def _load_macho_slices_via_cli(binary_path):
    """Shell to `bugsee-cli dsym slices <binary>` and return a
    `{arch: uuid}` dict, or None when the CLI is unavailable / its
    output can't be parsed.

    Mirrors the SDK BugseeAgent's `_load_macho_slices_via_cli` so
    `_extract_uuid_from_app` can pick the preferred arch's UUID on
    fat binaries — same posture as the SDK side, which means the two
    producers emit byte-identical uuids for the same artefact."""
    if not binary_path:
        return None
    cli = shutil.which("bugsee-cli")
    if not cli:
        return None
    try:
        result = subprocess.run(
            [cli, "dsym", "slices", binary_path],
            capture_output=True, text=True, timeout=30, check=False,
        )
        if result.returncode != 0:
            return None
        out = (result.stdout or "").strip()
        if not out:
            return None
        data = json.loads(out)
        if not isinstance(data, list):
            return None
    except _CLI_CATCHALL_EXCEPTIONS:
        return None
    slices = {}
    for entry in data:
        if not isinstance(entry, dict):
            continue
        uuid_str = entry.get('uuid')
        arch = entry.get('arch')
        if not isinstance(uuid_str, str) or not isinstance(arch, str):
            continue
        # First-seen wins for duplicate arch entries — matches the
        # SDK side's behaviour (rare exotic case).
        if arch not in slices:
            slices[arch] = uuid_str
    return slices


def _extract_uuid_from_app(app_path):
    """Extract the main executable's Mach-O `LC_UUID` from `app_path`
    and format it the way the iOS SDK reports it at runtime — 32
    lowercase hex chars, no dashes. Returns None on any failure
    (missing CFBundleExecutable, binary absent, CLI missing).

    Prefers the arch-aware `bugsee-cli dsym slices <main_binary>`
    subcommand and picks the preferred-arch UUID via the cascade
    `arm64 → arm64e → x86_64 → arm64-simulator → x86_64-simulator →
    first reported`. Falls back to the flat `dsym uuid` subcommand
    only when slices returns None (older bugsee-cli versions that
    predate the slices subcommand, or when the CLI isn't on PATH).

    Mirrors the SDK BugseeAgent's `get_main_executable_uuid` posture
    exactly so the fastlane producer path and the SDK producer path
    emit the SAME uuid for the same fat-binary build — without this
    cross-source consistency the back-end's `crash.uuid → build`
    join would only match on whichever producer happened to upload
    the build record.

    The format matches `BGSCrashReport.m`'s LC_UUID reporting so
    the back-end can join `crash.uuid → build.uuid` deterministically.
    """
    if not app_path or not os.path.isdir(app_path):
        return None
    plist_path = os.path.join(app_path, 'Info.plist')
    # `_read_info_plist` returns `{}` for non-dict CLI output, so
    # `.get()` is safe without an isinstance guard.
    info = _read_info_plist(plist_path)
    executable_name = info.get('CFBundleExecutable')
    if not executable_name:
        return None
    binary_path = os.path.join(app_path, executable_name)
    if not os.path.isfile(binary_path):
        return None
    # Prefer the arch-aware `dsym slices` subcommand so a fat binary's
    # arm64 slice (the one the iOS runtime SDK reports at crash time)
    # wins over x86_64/simulator slices that may appear first in the
    # archive's load-command order. Mirrors the SDK BugseeAgent's
    # `get_main_executable_uuid` posture exactly — without this, the
    # fastlane producer path and the SDK producer path could emit
    # different uuids for the same fat-binary build.
    slices = _load_macho_slices_via_cli(binary_path)
    candidate_uuid = None
    if slices:
        for arch in _PREFERRED_MACHO_ARCHS:
            if arch in slices:
                candidate_uuid = slices[arch]
                break
        if candidate_uuid is None:
            # Exotic arch — take the first reported. Deterministic
            # because the dict preserved insertion order from the CLI
            # output (Python 3.7+).
            candidate_uuid = next(iter(slices.values()))

    # Fallback to the flat `dsym uuid` subcommand (for older bugsee-cli
    # versions or when slices returned None — e.g. CLI not on PATH and
    # the helper short-circuited).
    if candidate_uuid is None:
        uuids = _parse_dsym_via_cli(binary_path)
        if uuids:
            candidate_uuid = uuids[0]

    # Funnel through the shared choke-point helper so the canonical
    # shape contract (32 lowercase hex chars, no dashes, whitespace-
    # only → None) lives in one place. Makes a regression that flipped
    # the normalisation rule trivially visible — every caller flows
    # through `_normalise_build_uuid`.
    return _normalise_build_uuid(candidate_uuid)


def _collect_build_metadata():
    """Read Xcode environment + Info.plist into the build-registration
    POST body shape. Mirrors the Android plugin's metadata block —
    the appserver / viewer consume the same field names regardless
    of platform.

    Returns a tuple of `(body_dict, dwarf_uuid_or_none)`. The
    body's `uuid` carries the Mach-O image UUID extracted from the
    dSYM via dwarfdump; the value is also returned so the caller
    can pass it to the symbols-upload step without re-running
    dwarfdump.
    """
    build_dir = os.environ.get('TARGET_BUILD_DIR') or options.build_dir or ''
    info_path_rel = os.environ.get('INFOPLIST_PATH', '')
    info_path = os.path.join(build_dir, info_path_rel) if info_path_rel else ''
    info = _read_info_plist(info_path)

    version = info.get('CFBundleShortVersionString') \
        or os.environ.get('MARKETING_VERSION') \
        or (options.version if options.version else None)
    build_number = info.get('CFBundleVersion') \
        or os.environ.get('CURRENT_PROJECT_VERSION') \
        or (options.build if options.build else None)
    bundle_id = info.get('CFBundleIdentifier') \
        or os.environ.get('PRODUCT_BUNDLE_IDENTIFIER')

    body = {
        # Mach-O UUID is filled in by the caller (after dwarfdump).
        "uuid": None,
        "package_id":          bundle_id,
        "version":             str(version) if version is not None else None,
        "build":               str(build_number) if build_number is not None else None,
        "build_configuration": os.environ.get('CONFIGURATION'),
        # iOS deploy format. The appserver's ALLOWED_BUILD_FORMATS
        # set includes 'ipa' alongside 'apk' / 'aab'.
        "format":              "ipa",
        "has_mapping":         False,  # no Java-style ProGuard mapping on iOS
        "build_metadata": {
            "machine": {
                # `host` is the CI-provider-aware label (e.g.
                # `github-actions:Linux-X64`); falls back to
                # platform.node() for local-archive runs where no
                # provider env var is set. The richer label lets the
                # dashboard cluster runs by runner across platforms.
                "host": resolve_machine_label() or platform.node(),
                "os":   platform.platform(),
                "arch": platform.machine(),
            },
            "build_system": {
                "type":    "xcode",
                # `XCODE_VERSION_ACTUAL` is the numeric form Xcode
                # exports (`"1620"` for 16.2.0); the resolver
                # normalises to the dotted form the dashboard
                # displays. Falls back to `xcodebuild -version`.
                "version": resolve_xcode_version(),
            },
            "agent": {
                "name":    "BugseeAgent",
                # Resolved relative to the script — keeps the value
                # honest even when the SDK ships multiple agent
                # versions in different distributions.
                "script":  os.path.basename(__file__),
            },
        },
    }

    # VCS metadata. Sibling field to `build_metadata` — matches the
    # Android Gradle plugin's wire shape and the appserver's
    # `sanitizeVcs` accept-list. Omit the field entirely when no
    # provider was detected AND the git fallback didn't surface a
    # commit (e.g. /tmp archive without a .git dir) — empty `vcs: {}`
    # records would still pass `sanitizeVcs` but pollute the dashboard.
    vcs = resolve_vcs_metadata(
        os.environ.get('SRCROOT')
        or os.environ.get('PROJECT_DIR')
        or os.getcwd()
    )
    if vcs:
        body["vcs"] = vcs

    return body


# -----------------------------------------------------------------
# Artifact packaging (synthetic .ipa from `.app`)
# -----------------------------------------------------------------

# File extensions that are already compressed; storing them with
# DEFLATE wastes CPU without saving bytes. Mirrors the SDK
# BugseeAgent's (`tools.bundle/BugseeAgent::_IPA_STORE_EXTENSIONS`)
# and the Android Gradle plugin's `BundleZipNormalizer` set. Keep in
# sync — divergence would make the byte-deterministic IPA dedup that
# the back-end relies on break across producers.
_IPA_STORE_EXTENSIONS = (
    # Image / video / audio
    ".png", ".jpg", ".jpeg", ".gif", ".bmp", ".tiff", ".webp", ".heic",
    ".mp4", ".mov", ".m4v", ".avi", ".webm",
    ".mp3", ".m4a", ".aac", ".ogg", ".flac", ".wav",
    # Archive / asset-catalog / package formats
    ".zip", ".gz", ".bz2", ".xz", ".7z",
    ".car",  # Asset catalog
    ".pdf",
    # Compiled fonts + binary glyph caches
    ".woff", ".woff2", ".otf", ".ttf",
)

# MS-DOS date/time epoch is 1980-01-01; picking a fixed value gives
# the zip a stable mtime across rebuilds so two archives of identical
# bits produce byte-identical synthetic IPAs. Mirrors the SDK side
# (`tools.bundle/BugseeAgent::_IPA_FIXED_MTIME`) and the Android
# Gradle plugin's `DOS_EPOCH_LOCAL`.
_IPA_FIXED_MTIME = (1980, 1, 1, 0, 0, 0)


def package_app_as_ipa(app_path, output_ipa_path):
    """Zip `<App>.app` as `Payload/<App>.app/...` into an .ipa.

    Byte-deterministic — entries sorted by name, mtimes pinned. Two
    runs over the same source tree produce hash-identical output, so
    the back-end can dedupe re-uploads by content sha. Compression
    method per-entry: STORE (no recompression) for already-compressed
    formats (PNG/JPG/MP4/.car/...), DEFLATE for plists / strings /
    Mach-O / etc. Same posture as the SDK BugseeAgent's
    `package_app_as_ipa` so artefacts produced by either producer
    are interchangeable on the back-end.

    DOES NOT add iTunesMetadata.plist or code signing — neither is
    needed for size analysis (the back-end's `_analyze_bundle` walks
    `Payload/*.app` and runs the categorisation heuristics off the
    Mach-O + resource tree only).
    """
    with zipfile.ZipFile(output_ipa_path, 'w', zipfile.ZIP_DEFLATED) as zf:
        for root, dirs, files in os.walk(app_path):
            # Sort in place so `os.walk` traverses in a deterministic
            # order — filesystem enumeration is otherwise non-
            # deterministic (and differs between APFS / HFS+ / NFS).
            dirs.sort()
            files.sort()
            for f in files:
                src = os.path.join(root, f)
                if os.path.islink(src):
                    # Real IPAs don't carry symlinks; zipfile can't
                    # encode them; skip.
                    continue
                rel = os.path.relpath(src, os.path.dirname(app_path))
                arcname = os.path.join('Payload', rel)
                method = (
                    zipfile.ZIP_STORED
                    if f.lower().endswith(_IPA_STORE_EXTENSIONS)
                    else zipfile.ZIP_DEFLATED
                )
                info = zipfile.ZipInfo(filename=arcname, date_time=_IPA_FIXED_MTIME)
                info.compress_type = method
                # Preserve POSIX exec bits on the embedded Mach-O —
                # otherwise the archive encodes as plain data and the
                # back-end's executable-detection heuristics (e.g.
                # "is this the main binary?") lose a signal.
                try:
                    st_mode = os.stat(src).st_mode
                    info.external_attr = (st_mode & 0xFFFF) << 16
                except OSError:
                    pass
                # Stream each file into the archive instead of
                # `zf.writestr(info, fp.read())` — the latter slurps
                # the entire source file into a transient bytes
                # buffer, doubling RSS for every embedded Mach-O. A
                # 300 MB main binary + 100 MB Swift stdlib + asset
                # catalogs would peak well over 1 GB on a CI runner
                # with 4 GB total. `zf.open(info, 'w')` returns a
                # stream-capable target; copy in 64 KB chunks.
                # `compress_type` MUST be set on the ZipInfo BEFORE
                # `zf.open` consumes it (already done above).
                with open(src, 'rb') as fp, zf.open(info, 'w') as dst:
                    shutil.copyfileobj(fp, dst, length=65536)
    return output_ipa_path


def _normalise_build_uuid(raw):
    """Coerce a Mach-O LC_UUID string to the canonical wire format
    the back-end uses for `crash.uuid → build.uuid` join: 32
    lowercase hex chars, no dashes, no whitespace. Matches the iOS
    runtime SDK's `BGSCrashReport.m` shape verbatim. Returns None on
    empty/whitespace-only input so callers never write a meaningless
    uuid into the registration payload.

    Used at every uuid-cascade exit point — `_extract_uuid_from_app`
    (Mach-O), `_extract_first_dwarf_uuid` (dSYM scan via dwarfdump),
    and the random-fallback in run_artifact_upload_flow (uuid4) —
    so all three steps produce a single canonical shape regardless
    of which fallback hit."""
    if not raw:
        return None
    candidate = str(raw).replace('-', '').strip().lower()
    return candidate or None


def _extract_first_dwarf_uuid():
    """Scan the dSYM folder for the FIRST Mach-O UUID we can find
    via dwarfdump. The Android plugin sends a single per-build
    UUID; we mirror that posture by surfacing the main binary's
    first arch slice UUID (typically arm64). Returns None on any
    error or if no dSYMs are present.

    Returns the value already normalised through
    `_normalise_build_uuid` so callers don't need to know whether
    `parseDSYM`'s underlying tool (bugsee-cli OR dwarfdump fallback)
    emitted uppercase-hyphenated, lowercase-hyphenated, or
    lowercase-no-dashes — they all converge here."""
    folder = options.dsym_folder
    if not folder or not os.path.isdir(folder):
        return None
    for root, dirs, files in os.walk(folder):
        if not root.endswith('dSYM/Contents/Resources/DWARF'):
            continue
        for f in files:
            full = os.path.join(root, f)
            if os.path.islink(full) or os.stat(full).st_size == 0:
                continue
            uuids = parseDSYM(full)
            if uuids:
                return _normalise_build_uuid(uuids[0])
    return None


def _resolve_product_binary_path():
    """Resolve the path to the linked product binary for the
    vendored-framework scan. Uses Xcode env vars
    `EXECUTABLE_PATH` and `TARGET_BUILD_DIR` which together name
    the exact Mach-O the linker emitted for this build. Returns
    None when run outside Xcode."""
    build_dir = os.environ.get('TARGET_BUILD_DIR') or options.build_dir
    exe_path = os.environ.get('EXECUTABLE_PATH')
    if not build_dir or not exe_path:
        return None
    candidate = os.path.join(build_dir, exe_path)
    return candidate if os.path.isfile(candidate) else None


# ──────────────────────────────────────────────────────────────────
# Dependency-source discovery
# ──────────────────────────────────────────────────────────────────

def _find_first_above(start_dir, filename, max_levels=6):
    """Walk up from `start_dir` looking for `filename`. CocoaPods
    / SPM / Carthage lockfiles all sit at the project root, which
    is somewhere ABOVE the Xcode build directory at runtime — the
    walk-up locates them without the caller having to know the
    exact relative depth.

    `max_levels` caps the climb so a misconfigured environment
    can't send us all the way to `/`. Returns the absolute path on
    hit or None on miss.
    """
    if not start_dir:
        return None
    current = os.path.abspath(start_dir)
    for _ in range(max_levels):
        candidate = os.path.join(current, filename)
        if os.path.isfile(candidate):
            return candidate
        parent = os.path.dirname(current)
        if parent == current:
            return None
        current = parent
    return None


def _collect_all_dependencies_via_cli(cli_binary, project_root,
                                       product_binary):
    """Shell to `bugsee-cli ios-deps collect` and parse the JSON.

    Part of the Option-C migration that moved iOS dep parsing to
    the Rust CLI as the single canonical implementation. The
    in-process Python parsers below are preserved as a cold-start
    fallback when the CLI isn't available.

    Returns `(entries, scope_label, truncated)` on success or
    `None` on any failure (subprocess error, malformed JSON,
    non-zero exit). The caller falls back to the Python
    implementation on None.
    """
    if not cli_binary or not project_root:
        return None
    cmd = [cli_binary, "ios-deps", "collect",
           "--project-root", project_root]
    if product_binary:
        cmd.extend(["--product-binary", product_binary])
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True,
            timeout=30, check=False,
        )
        if result.returncode != 0:
            return None
        out = (result.stdout or "").strip()
        if not out:
            return None
        data = json.loads(out)
        # Shape validation (parity with the SDK side and the dsym
        # helper). A future CLI shape change — accidental `"entry"`
        # rename, list-instead-of-dict, non-string ids — must
        # surface as "fall back to Python parsers" rather than
        # crashing in `_build_dependencies_payload` further down
        # the pipeline.
        if not isinstance(data, dict):
            return None
        raw_entries = data.get("entries")
        if not isinstance(raw_entries, list):
            return None
        entries = [e for e in raw_entries if isinstance(e, dict)
                                            and isinstance(e.get("id"), str)]
        return (
            entries,
            data.get("scope_label") or "all",
            bool(data.get("truncated")),
        )
    except _CLI_CATCHALL_EXCEPTIONS:
        return None


def _collect_all_dependencies(project_root):
    """Run every parser against the project root and return the
    merged entry list plus the `(scope_label, truncated)` tuple
    the payload builder needs.

    `project_root` is the directory we walk up from to find each
    source lockfile. In an Xcode build that's `SRCROOT` (or
    `$PROJECT_DIR`); outside Xcode (CLI testing) the caller passes
    the project root explicitly.

    Implementation: prefers `bugsee-cli ios-deps collect` (the
    single cross-language source of truth, ported from these
    Python parsers — see `bugsee-cli/src/cli/ios_deps.rs`). Falls
    back to the in-process Python parsers below when the CLI
    isn't available. Same migration pattern the VCS resolver
    landed first.
    """
    # Resolve binary path up-front — needed for both CLI invocation
    # (`--product-binary <path>`) and the Python fallback.
    binary = _resolve_product_binary_path()

    cli_path_opt = None
    cli_version_opt = None
    try:
        cli_path_opt = getattr(options, 'cli_path', None)
        cli_version_opt = getattr(options, 'cli_version', None)
    except NameError:
        pass
    cli = resolveCli(cli_path_opt, cli_version_opt)
    if cli:
        via_cli = _collect_all_dependencies_via_cli(cli, project_root, binary)
        if via_cli is not None:
            return via_cli

    podfile = _find_first_above(project_root, 'Podfile.lock')
    package_resolved = (
        _find_first_above(project_root, 'Package.resolved')
        # SPM CLI writes Package.resolved at the package root, but
        # Xcode-managed projects keep one under
        # `*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/`.
        # Search for that variant too if the top-level miss.
        or _find_first_above(project_root,
                             os.path.join('xcshareddata', 'swiftpm',
                                          'Package.resolved'))
    )
    cartfile = _find_first_above(project_root, 'Cartfile.resolved')

    pods_entries = _parse_podfile_lock(podfile) if podfile else []
    spm_entries  = _parse_package_resolved(package_resolved) if package_resolved else []
    cart_entries = _parse_cartfile_resolved(cartfile) if cartfile else []
    vendored_entries = _parse_vendored_frameworks(binary) if binary else []

    merged, truncated = _merge_dep_entries(
        pods_entries, spm_entries, cart_entries, vendored_entries,
    )
    # `scope` here describes the COLLECTION scope (Android plugin
    # uses 'runtime' / 'runtime_direct_only'). iOS doesn't have
    # that distinction; surface 'all' so the worker's
    # compatibility check still has a stable token to compare
    # against across builds.
    return merged, "all", truncated


# ──────────────────────────────────────────────────────────────────
# Bugsee API client (build registration + presigned upload)
# ──────────────────────────────────────────────────────────────────

def _request_build_registration(app_token, endpoint, body_json):
    """POST the build registration body to /v2/apps/{token}/builds
    and return the unwrapped result payload (the inner `result`
    object the appserver wraps every v2 response in). Returns None
    on any error — callers fall back to skipping the deps upload
    step.

    Response shape from the appserver:
      success: {"ok": true, "result": { <payload> }}
      failure: {"ok": false, "error": { "type": ..., "message": ... }}

    The Android plugin's `ApiEndpoint.unwrapResult` performs the
    same unwrap; we mirror its posture so the caller sees a flat
    payload regardless of platform.
    """
    url = endpoint.rstrip('/') + '/v2/apps/' + urllib.parse.quote(app_token) + '/builds'
    try:
        req = urllib.request.Request(
            url, data=body_json.encode('utf-8'),
            headers={'Content-Type': 'application/json'},
            method='POST',
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            raw = json.loads(resp.read().decode('utf-8'))
    except (urllib.error.URLError, urllib.error.HTTPError,
            ValueError, OSError) as e:
        print("Bugsee: build registration failed: %s" % e)
        return None

    # Unwrap `{ok, result}` envelope. `ok: false` is surfaced as a
    # logged error and None return so the caller can short-circuit.
    if not isinstance(raw, dict):
        print("Bugsee: build registration: unexpected response type %s"
              % type(raw).__name__)
        return None
    if raw.get('ok') is False:
        err = raw.get('error') or {}
        if isinstance(err, dict):
            print("Bugsee: build registration rejected: %s (%s)"
                  % (err.get('message', '(no message)'), err.get('type', '?')))
        else:
            print("Bugsee: build registration rejected (no error detail).")
        return None
    result = raw.get('result')
    if isinstance(result, dict):
        return result
    # Some appserver routes return a flat payload without the
    # `{ok, result}` envelope (legacy endpoints). Return the raw
    # dict in that case so we don't lose information.
    return raw


def _put_dependencies_blob(endpoint_url, gz_bytes):
    """PUT the gzipped deps JSON to the presigned URL the appserver
    returned. Matches the Android plugin's signing posture:
    `Content-Type: application/octet-stream`, no Content-Encoding
    header on the producer PUT (the worker sets it when moving
    bytes to the store bucket). Returns True on success.
    """
    try:
        req = urllib.request.Request(
            endpoint_url, data=gz_bytes,
            headers={
                'Content-Type': 'application/octet-stream',
                # Precise Content-Length so urllib doesn't fall back
                # to chunked transfer-encoding (which S3 presigned
                # PUT signatures don't accept — the worker would see
                # the body but the signature check 403s). The sibling
                # `_put_timings_blob` and `_put_artifact_blob` both
                # set this explicitly; this helper used to rely on
                # urllib's auto-derive which works on most paths but
                # was inconsistent with the documented S3 signing
                # posture.
                'Content-Length': str(len(gz_bytes)),
            },
            method='PUT',
        )
        with urllib.request.urlopen(req, timeout=120) as resp:
            status = getattr(resp, 'status', 200)
            return 200 <= status < 300
    except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
        print("Bugsee: dependencies upload failed: %s" % e)
        return False


def _put_timings_blob(url, gz_bytes, debug=False):
    """Best-effort PUT of the gzipped per-task timeline DETAIL blob to
    the presigned `timings_upload_endpoint` the metadata POST returned.

    Mirrors `_put_dependencies_blob` exactly — independent of the
    artefact upload, runs on the build-info-only path too, never
    raises (a failed PUT degrades to "no Gantt chart for this build"
    and must not break the user's archive flow). Returns True on a
    2xx, False otherwise.

    `Content-Type` is hard-set to `application/octet-stream` because
    the back-end signs the presigned URL over exactly that value —
    S3 403s the PUT on any Content-Type mismatch.
    """
    if not url or not gz_bytes:
        return False
    try:
        put_req = urllib.request.Request(url, data=gz_bytes, method='PUT')
        # Precise Content-Length so the signed request body-length
        # matches; chunked transfer-encoding breaks S3 presigned PUTs.
        put_req.add_header('Content-Length', str(len(gz_bytes)))
        put_req.add_header('Content-Type', 'application/octet-stream')
        with urllib.request.urlopen(put_req, timeout=120) as resp:
            status = resp.status
    except urllib.error.HTTPError as e:
        print("Bugsee: timings PUT failed (HTTP %d)" % e.code)
        return False
    except Exception as e:
        print("Bugsee: timings PUT network error: %s" % e)
        return False

    if 200 <= status < 300:
        if debug:
            print("Bugsee: timings blob uploaded (%d bytes, HTTP %d)"
                  % (len(gz_bytes), status))
        return True
    print("Bugsee: timings PUT unexpected status: %d" % status)
    return False


def _put_artifact_blob(url, ipa_path, debug=False):
    """Best-effort PUT of the .ipa bytes to the presigned
    `endpoint` the metadata POST returned.

    Streams from disk instead of slurping into memory — modern iOS
    apps can exceed 300 MB once extensions + assets are included,
    and macOS CI runners have modest memory budgets.

    `Content-Type` is hard-set to `application/octet-stream`
    (matches the SDK BugseeAgent's upload_build posture; the
    back-end signs the presigned URL over exactly that content
    type, so S3 403s on any mismatch). `Content-Length` is
    pre-computed because urllib's default chunked transfer-encoding
    breaks S3 presigned PUT signatures.
    """
    if not url or not ipa_path:
        return False
    try:
        ipa_size = os.path.getsize(ipa_path)
    except OSError as e:
        print("Bugsee: could not stat artefact for upload: %s" % e)
        return False
    try:
        with open(ipa_path, 'rb') as fp:
            put_req = urllib.request.Request(url, data=fp, method='PUT')
            put_req.add_header('Content-Length', str(ipa_size))
            put_req.add_header('Content-Type', 'application/octet-stream')
            with urllib.request.urlopen(put_req, timeout=600) as resp:
                status = resp.status
    except urllib.error.HTTPError as e:
        print("Bugsee: artefact PUT failed (HTTP %d)" % e.code)
        return False
    except Exception as e:
        print("Bugsee: artefact PUT network error: %s" % e)
        return False

    if 200 <= status < 300:
        if debug:
            print("Bugsee: artefact uploaded (%d bytes, HTTP %d)"
                  % (ipa_size, status))
        return True
    print("Bugsee: artefact PUT unexpected status: %d" % status)
    return False


def run_artifact_upload_flow(app_token, endpoint, app_path,
                             version=None, build_number=None,
                             request_artifact_upload=True,
                             debug=False):
    """Package an `.app` into a synthetic `.ipa` and upload it to
    Bugsee for size analysis. Mirrors the SDK BugseeAgent's
    `run_size_analysis_flow` minus the chunked-upload opt-in and
    the in-build size-check evaluation (those can land in a
    follow-up).

    Returns True on overall success (build registered AND, when
    requested, artefact bytes shipped); False on any failure.

    `request_artifact_upload=False` flips this into a build-info-
    only registration that records the artefact_size on the
    server WITHOUT shipping the bytes — useful for firewalled CI
    or privacy-sensitive setups where the dashboard's size-trend
    chart is enough.
    """
    if not app_path or not os.path.isdir(app_path):
        print("Bugsee: --app-path is required and must be a directory; got %r"
              % app_path)
        return False
    if not app_path.endswith('.app'):
        print("Bugsee: --app-path must end in .app; got %r" % app_path)
        return False

    temp_dir = tempfile.mkdtemp(prefix='bugsee-artifact-')
    try:
        # Resolve Info.plist provenance BEFORE packaging — we want
        # `package_id` + `version` + `build` on the registration
        # payload so the back-end's /builds/baseline lookup keys on
        # the same triple the SDK side uses. Otherwise every fastlane-
        # registered build lives in its own bucket and the size-trend
        # chart never finds a delta.
        bundle_id, plist_version, plist_build = resolve_bundle_info_from_app(app_path)
        # Caller-supplied args override the plist (a CI step may want
        # to label a build differently from what Xcode wrote in).
        effective_version = version or plist_version
        effective_build = build_number or plist_build

        # Sanitise the .ipa filename stem against path-traversal — the
        # bundle id / app name flow from Info.plist values we read but
        # don't fully validate.
        stem = bundle_id or os.path.basename(app_path)[:-4] or 'build'
        safe_stem = re.sub(r'[^A-Za-z0-9._-]', '_', os.path.basename(stem))
        ipa_path = os.path.join(temp_dir, '%s.ipa' % (safe_stem or 'build'))
        print("Bugsee: packaging %s → %s"
              % (os.path.basename(app_path), ipa_path))
        package_app_as_ipa(app_path, ipa_path)

        try:
            artifact_size = os.path.getsize(ipa_path)
        except OSError:
            artifact_size = 0

        # Build the registration payload. Mirrors the SDK's
        # `run_size_analysis_flow` payload shape so the back-end's
        # `_register_build` route treats both producers identically.
        payload = {
            'format': 'ipa',
            'request_artifact_upload': bool(request_artifact_upload),
        }
        if bundle_id:
            # `package_id` is one of the back-end's baseline lookup
            # keys. Without it the dashboard size-trend chart never
            # finds a baseline for this build's family.
            payload['package_id'] = bundle_id
        if effective_version:
            payload['version'] = effective_version
        if effective_build:
            payload['build'] = effective_build
        if artifact_size > 0:
            payload['artifact_size'] = artifact_size
        # $CONFIGURATION is set by Xcode in build phases and by
        # `xcodebuild` invocations; the second baseline-lookup key
        # the back-end consumes. Optional — when absent, the back-end
        # treats it as the implicit "Release" bucket.
        config = (os.environ.get('CONFIGURATION') or '').strip()
        if config:
            payload['build_configuration'] = config

        # `uuid` is the build identifier the back-end uses to join
        # crashes to this build (`crash.uuid → build`). Resolution
        # cascade matches the SDK's posture:
        #   1. Main executable's Mach-O LC_UUID (deterministic per
        #      linker invocation; the same value the runtime reports).
        #   2. First dwarf UUID from the legacy dSYM scan (when the
        #      fastlane lane runs the dSYM upload action in the same
        #      invocation, options.dsym_folder is set).
        #   3. uuid.uuid4() — pure random fallback. The build record
        #      is still useful for the size-trend chart but crash-
        #      to-build join is best-effort in this case.
        # All cascade exits funnel through `_normalise_build_uuid`
        # so the registration payload's `uuid` is always the canonical
        # 32-char lowercase-no-dash shape the back-end joins on.
        # `_extract_uuid_from_app` and `_extract_first_dwarf_uuid`
        # both already normalise on their way out (#2/#4/#11 fix);
        # the random fallback also goes through the helper for the
        # same reason.
        build_uuid = _extract_uuid_from_app(app_path)
        if not build_uuid:
            try:
                build_uuid = _extract_first_dwarf_uuid()
            except NameError:
                build_uuid = None
        if not build_uuid:
            build_uuid = _normalise_build_uuid(str(uuid.uuid4()))
        payload['uuid'] = build_uuid

        # VCS metadata (best-effort). Resolves via bugsee-cli when on
        # PATH, falls back to in-process Python otherwise. Guard
        # against the same `options`-NameError window as the dSYM
        # UUID extraction above (resolve_vcs_metadata's CLI path may
        # consult `options.cli_path` / `options.cli_version`).
        try:
            vcs = resolve_vcs_metadata(os.getcwd())
        except NameError:
            vcs = None
        if vcs:
            payload['vcs'] = vcs

        if debug:
            print("Bugsee: artefact registration payload = %s"
                  % json.dumps(payload))

        result = _request_build_registration(
            app_token, endpoint, json.dumps(payload))
        if result is None:
            return False

        if not request_artifact_upload:
            # Build-info-only path: nothing more to ship. The server
            # recorded artifact_size for the size-trend chart.
            if debug:
                print("Bugsee: build-info-only registration complete")
            return True

        presigned = result.get('endpoint') if isinstance(result, dict) else None
        if not presigned:
            print("Bugsee: build registration returned no presigned endpoint")
            return False

        return _put_artifact_blob(presigned, ipa_path, debug=debug)
    finally:
        shutil.rmtree(temp_dir, ignore_errors=True)


def _upload_build_info_bundle(upload_url, deps_gz, timings_gz):
    """Ship the build-info components as ONE zstd bundle via
    `bugsee-cli upload build-info --upload-url <url>` (pre-signed mode:
    the plugin already registered the build, so the CLI just PUTs).

    `deps_gz` / `timings_gz` are the gzipped per-blob payloads; they're
    gunzipped here because the bundle's `dependencies.json` /
    `timings.json` entries carry RAW JSON (the CLI does the zstd packing
    and the worker re-gzips on store, so the stored bytes match the legacy
    per-blob path). At least one must be non-None.

    Returns True on success. Returns False on ANY failure — including no
    resolvable CLI — so the caller falls back to the legacy per-blob gzip
    PUTs, which target independent presigned URLs (an independent upload
    mechanism, so retrying them is worthwhile even on a substantive
    bundle failure).
    """
    cli = resolveCli(getattr(options, 'cli_path', None),
                     getattr(options, 'cli_version', None))
    if not cli:
        return False
    tmpdir = tempfile.mkdtemp(prefix='bugsee-build-info-')
    try:
        argv = [cli, "upload", "build-info", "--upload-url", upload_url]
        if deps_gz is not None:
            deps_path = os.path.join(tmpdir, "dependencies.json")
            with open(deps_path, 'wb') as fp:
                fp.write(gzip.decompress(deps_gz))
            argv += ["--deps", deps_path]
        if timings_gz is not None:
            timings_path = os.path.join(tmpdir, "timings.json")
            with open(timings_path, 'wb') as fp:
                fp.write(gzip.decompress(timings_gz))
            argv += ["--timings", timings_path]
        result = subprocess.run(
            argv, capture_output=True, text=True, timeout=120, check=False)
        stderr = (result.stderr or '').strip()
        if stderr:
            print("Bugsee: bugsee-cli output:\n%s" % stderr)
        return result.returncode == 0
    except _CLI_CATCHALL_EXCEPTIONS as e:
        print("Bugsee: build-info bundle CLI invocation failed: %s" % e)
        return False
    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)


def _run_dependencies_pipeline(app_token, project_root):
    """Top-level driver wired into [main] when --deps is enabled.

    Collects + uploads the project's dependency graph AND the
    build's xcactivitylog-derived timings (when available) in ONE
    build-registration round-trip. Both pieces of data are
    optional — if neither produced useful output the function
    short-circuits before the network call. Otherwise the
    registration POST carries:

      - `build_metadata.timings`  — inline summary (total_ms,
        category sums, top tasks); always present when the
        xcactivitylog was found.
      - `dependencies_summary`   — total/direct/transitive counts,
        collection_config; present when at least one lockfile
        parsed.

    The server responds with up to two presigned PUT endpoints:

      - `dependencies_upload_endpoint` — for the full deps blob.
      - `timings_upload_endpoint`      — for the full per-task
        Gantt-detail blob.

    Each PUT is best-effort and independent: a failed deps PUT
    does NOT skip the timings PUT, and vice versa. The function
    returns True only when registration succeeded AND every
    attempted PUT succeeded; partial failures return False but
    don't raise.

    Failures here MUST NOT block the existing symbols-upload
    step — both pipelines are independent.
    """
    # Per-feature gating. Each side of the cross-producer
    # handshake decides independently whether THIS agent should
    # contribute deps / timings — see the --no-deps / --no-timings
    # OptionParser entries. The fastlane Ruby action sets these
    # flags based on the manifest the iOS SDK's BugseeAgent build
    # phase emitted (or didn't) for this build.
    collect_deps    = getattr(options, 'collect_deps',    True)
    collect_timings = getattr(options, 'collect_timings', True)

    if collect_deps:
        entries, scope_label, truncated = _collect_all_dependencies(project_root)
    else:
        entries, scope_label, truncated = [], 'all', False

    if collect_timings:
        timings_summary, timings_gz = resolve_build_timings(os.environ)
    else:
        timings_summary, timings_gz = None, None

    have_deps    = bool(entries)
    have_timings = timings_summary is not None

    if not have_deps and not have_timings:
        print("Bugsee: no dependency sources found and no build timings "
              "available; skipping build-info upload.")
        return False

    body = _collect_build_metadata()
    # Guard against writing `"uuid": null` into the POST body when the
    # dSYM scan yields nothing (e.g. a lane that ships build-info-only
    # with no dSYMs alongside). The historic assignment unconditionally
    # set the value, leaking the None into the JSON.
    #
    # `_extract_first_dwarf_uuid` now normalises through
    # `_normalise_build_uuid` on its way out (lifted from the per-
    # callsite normalisation that used to live only in
    # run_artifact_upload_flow), so `dwarf_uuid` here is already the
    # canonical 32-char lowercase-no-dash shape the back-end joins on.
    dwarf_uuid = _extract_first_dwarf_uuid()
    if dwarf_uuid:
        body["uuid"] = dwarf_uuid
    body["request_artifact_upload"]      = False
    body["request_dependencies_upload"]  = have_deps
    body["request_timings_upload"]       = timings_gz is not None
    # Opt into the converged build-info bundle (Phase D). The server only
    # signs a build_info_upload_endpoint when the org's
    # BUGSEE_FEATURE_BUILD_INFO_BUNDLE_ENABLED flag is on; the deps/timings
    # flags above stay set so the legacy path remains available for
    # fallback (and for non-flagged orgs) during the soak.
    body["request_build_info_upload"]    = have_deps or have_timings

    deps_blob_gz = None
    if have_deps:
        deps_summary, deps_blob = _build_dependencies_payload(
            entries, truncated, scope_label,
            include_selected_reason=False,
            max_count=DEPENDENCIES_MAX_COUNT,
        )
        body["dependencies_summary"] = deps_summary
        deps_blob_gz = _gzip_json_bytes(deps_blob)

    if have_timings:
        # Inline timings summary lives under build_metadata so the
        # server-side rollup (total_ms, top tasks, category sums)
        # is available without fetching the detail blob. The blob
        # itself is uploaded separately via the presigned URL.
        body.setdefault("build_metadata", {})["timings"] = timings_summary

    response = _request_build_registration(
        app_token, options.endpoint, json.dumps(body))
    if not response:
        return False

    # Build-info bundle (Phase D): when the server signed a
    # build_info_upload_endpoint (the org is flagged on), the escape hatch
    # is off, and a CLI resolves, ship deps+timings as ONE zstd bundle via
    # `bugsee-cli upload build-info` instead of the two legacy gzip PUTs.
    # Fails closed — any miss/failure falls through to the legacy PUTs.
    build_info_endpoint = response.get('build_info_upload_endpoint')
    if (build_info_endpoint
            and not _env_truthy(os.environ.get('BUGSEE_LEGACY_BUILDINFO_GZIP'))
            and (have_deps or have_timings)):
        if _upload_build_info_bundle(
                build_info_endpoint, deps_blob_gz, timings_gz):
            print("Bugsee: build-info bundle uploaded via bugsee-cli.")
            return True
        print("Bugsee: build-info bundle unavailable/failed; falling back "
              "to legacy per-blob upload.")

    overall_ok = True

    if have_deps and deps_blob_gz is not None:
        deps_endpoint = response.get('dependencies_upload_endpoint')
        if not deps_endpoint:
            print("Bugsee: server did not return a dependencies upload "
                  "endpoint — skipping deps PUT.")
            overall_ok = False
        else:
            print("Bugsee: uploading dependencies blob (%d entries, "
                  "%d bytes gzipped)"
                  % (len(entries), len(deps_blob_gz)))
            if not _put_dependencies_blob(deps_endpoint, deps_blob_gz):
                overall_ok = False

    if timings_gz is not None:
        timings_endpoint = response.get('timings_upload_endpoint')
        if not timings_endpoint:
            # Older appservers may not surface the timings endpoint
            # yet — the inline summary still landed via the POST,
            # so this isn't a hard failure.
            print("Bugsee: server did not return a timings upload "
                  "endpoint — inline summary kept; per-task detail "
                  "blob skipped.")
        else:
            print("Bugsee: uploading build timings blob (%d bytes gzipped)"
                  % len(timings_gz))
            if not _put_timings_blob(timings_endpoint, timings_gz):
                overall_ok = False

    return overall_ok


def isInUploadedList(images, imageList):
    for image in images:
        if (image in imageList):
            return True
    return False

def saveUploadedList(images):
    print("Storing identifiers so we won't upload them again")
    with open(os.path.expanduser("~/.bugseeUploadList"), 'w+') as data_file:
        json.dump(images, data_file)
    return

def loadUploadedList():
    try:
        with open(os.path.expanduser("~/.bugseeUploadList")) as data_file:
            return json.load(data_file)
    except Exception as error:
        return []

def _parse_dsym_via_cli(fullPath):
    """Shell to `bugsee-cli dsym uuid <path>` for the UUID list.
    Returns a list of UUID strings on success, or None on any
    failure. Part of the Option-C migration that moved dSYM UUID
    extraction to the Rust CLI (which keys off
    `symbolic-debuginfo`'s Mach-O parser — no `/usr/bin/dwarfdump`
    dependency)."""
    if not fullPath:
        return None
    cli_path_opt = None
    cli_version_opt = None
    try:
        cli_path_opt = getattr(options, 'cli_path', None)
        cli_version_opt = getattr(options, 'cli_version', None)
    except NameError:
        pass
    cli = resolveCli(cli_path_opt, cli_version_opt)
    if not cli:
        return None
    try:
        result = subprocess.run(
            [cli, "dsym", "uuid", fullPath],
            capture_output=True, text=True, timeout=30, check=False,
        )
        if result.returncode != 0:
            return None
        out = (result.stdout or "").strip()
        if not out:
            return None
        data = json.loads(out)
        if not isinstance(data, list):
            return None
        # Each entry must be a UUID string.
        return [str(u) for u in data if isinstance(u, str)]
    except _CLI_CATCHALL_EXCEPTIONS:
        return None


def parseDSYM(fullPath):
    """Extract Mach-O UUIDs from a dSYM bundle or Mach-O binary.

    Prefers `bugsee-cli dsym uuid` (canonical Rust implementation;
    no /usr/bin/dwarfdump dependency). Falls back to the in-
    process dwarfdump shell-out below when the CLI isn't
    available."""
    via_cli = _parse_dsym_via_cli(fullPath)
    if via_cli is not None:
        return via_cli

    images = []
    try:
        out = subprocess.run(['/usr/bin/dwarfdump', '-u', fullPath], check=True, capture_output=True, text=True).stdout
        # UUID: 598A8EC3-B348-36C6-8B3A-0390B247EFF2 (arm64) /Users/finik/Downloads/BugseeDev
        lines = out.splitlines()

        for line in lines:
            searchObj = re.search(r'UUID: (.*) \((\w+)\)', line)
            if (searchObj):
                images.append(searchObj.group(1))

    except subprocess.CalledProcessError as e:
        return images

    return images

def deobfuscateDSYM(fullPath, mapsPath):
    try:
        out = subprocess.run(['/usr/bin/dsymutil', '--symbol-map', mapsPath, fullPath], check=True, capture_output=True, text=True).stdout
    except subprocess.CalledProcessError as e:
        return
    return

# Note on app icon attachment (removed in 1.1.0):
#
# The legacy upload pipeline shipped the Xcode-uncrushed launcher
# PNG inside the dSYM zip; the worker's symbols job extracted
# `icon.png` from the bundle root and called `icons.store_icon(...,
# 'build', ...)` (see worker/jobs/symbols.py). Two helpers — getIcon
# and uncrushIcon (running `xcrun pngcrush -revert-iphone-
# optimizations`) — produced that PNG.
#
# bugsee-cli's --type dsym path takes no --icon (the CLI rejects it
# at parse-time; see bugsee-cli/src/cli/debug_files.rs), so the
# build-extraction code path is dead. The dashboard falls back to
# the worker's appstore fetch (icon.source='appstore') for any app
# that's published on the App Store, but enterprise / TestFlight /
# internal builds now render without an icon until icon attachment
# is re-wired into the build registration body
# (`_request_build_registration` would be the place).
#
# The legacy helpers are removed here rather than left as comments
# because git history preserves them — searching for getIcon /
# uncrushIcon in the log of this file surfaces the exact 1.0.4
# implementation if someone needs to re-introduce it.


def getVersionAndBuild(zipFile):
    version = None
    build = None
    if options.dsym_list:
        searchObj = re.search(r'-([\w\.]+)-(\d+).dSYM.zip$', zipFile)
        if (searchObj):
            version = searchObj.group(1)
            build = searchObj.group(2)
    else:
        try:
            info_file_path = os.path.join(options.build_dir, os.environ['INFOPLIST_PATH'])
            # Argv list — never shell=True. The PlistBuddy invocation
            # used to be `subprocess.Popen([cmd], shell=True)` with the
            # info_file_path concatenated into the command string,
            # which broke quoting on any project path containing a
            # quote/apostrophe AND opened a shell-injection sink if
            # INFOPLIST_PATH or build_dir came from an attacker-
            # controlled env var. The list form bypasses the shell
            # entirely; quoting is no longer the script's problem.
            p = subprocess.Popen([
                '/usr/libexec/PlistBuddy',
                '-c', 'Print :CFBundleShortVersionString',
                '-c', 'Print :CFBundleVersion',
                info_file_path,
            ], stdout=subprocess.PIPE)
            stdout, stderr = p.communicate()
            version, build = stdout.decode().split()
        except Exception as error:
            return (None, None)

    return (version, build)

def requestEndPoint(version, build):
    encoded_data = json.dumps({
        'version': version,
        'build': build
        }).encode()

    req = urllib.request.Request(options.endpoint + '/apps/' + APP_TOKEN + '/symbols', data=encoded_data)
    req.add_header('Content-Type', 'application/json')
    response = urllib.request.urlopen(req)

    text = response.read()

    return json.loads(text.decode())

def uploadBundle(endpoint, filePath):
    # PUT the file via urllib instead of shelling to curl. The
    # original `curl -v -T "<filePath>" "<endpoint>"` was constructed
    # by string concatenation and passed to `subprocess.Popen([cmd],
    # shell=True)` — broken on any filePath/endpoint containing
    # quotes and a shell-injection sink for the server-returned
    # endpoint URL. urllib was already imported for adjacent
    # uploadStatus/requestEndPoint calls; reuse it.
    try:
        with open(filePath, 'rb') as f:
            data = f.read()
        req = urllib.request.Request(endpoint, data=data, method='PUT')
        with urllib.request.urlopen(req) as resp:
            return 200 <= resp.status < 300
    except Exception:
        return False

def updateStatus(symbolId):
    encoded_data = json.dumps({
        'status': 'uploading',
        }).encode()

    req = urllib.request.Request(options.endpoint + '/symbols/' + symbolId + '/status', data=encoded_data)
    req.add_header('Content-Type', 'application/json')
    response = urllib.request.urlopen(req)

    text = response.read()

    r = json.loads(text.decode())
    if (r and r.get('ok')):
        return True
    return False

def uploadZipFile(zipFileLocation):
    if options.version or options.build:
        version = options.version
        build = options.build
    else:
        version, build = getVersionAndBuild(zipFileLocation)

    r = requestEndPoint(version, build)
    if (r.get('ok') and r.get('endpoint')):
        print("Uploading to %s" % r.get('endpoint'))
        retries = 0
        while retries < 5:
            upload_result = uploadBundle(r.get('endpoint'), zipFileLocation)
            if upload_result:
                return True
            print("Uploading to %s failed. Retrying" % r.get('endpoint'))
            retries += 1

    return False

# ──────────────────────────────────────────────────────────────────
# Build timings via xcactivitylog (ported from SDK BugseeAgent)
#
# Parses Xcode's .xcactivitylog (SLF0-compressed binary format) to
# extract per-task durations + category rollups for the build
# registration's `build_metadata.timings` sub-object. Same schema
# the Android Gradle plugin's BuildTimingService emits, so the
# back-end renders iOS and Android timings from one wire shape.
# ──────────────────────────────────────────────────────────────────

_SLF_SECTION_CLASS = 'IDEActivityLogSection'
_SLF_COMMAND_CLASS = 'IDEActivityLogCommandInvocationSection'
_SLF_SECTION_CLASSES = frozenset((_SLF_SECTION_CLASS, _SLF_COMMAND_CLASS))

# SLF token delimiters. The three LENGTH-PREFIXED forms (`"` string,
# `%` className-def, `*` JSON/data blob) carry a DECIMAL length whose
# raw bytes follow; the rest are SIMPLE (`#` hex int, `^` hex double,
# `@` hex classRef, `(` array/object element count, `-` null).
_SLF_LEN_PREFIXED = b'"%*'
_SLF_SIMPLE = b'#^@(-'
_SLF_DELIMS = frozenset(_SLF_LEN_PREFIXED + _SLF_SIMPLE)
_SLF_LEN_PREFIXED_SET = frozenset(_SLF_LEN_PREFIXED)


# Per-category title classifier for iOS build events. Wire shape is
# the same as the Android Gradle plugin's (`managed_code_ms` /
# `native_ms` / `resources_ms` / `packaging_ms` / `other_ms`) so
# back-end + front-end render both platforms from a single schema.
# Semantic mapping for iOS:
#
#   managed_code_ms → never emitted on iOS. Reserved for JVM-
#                     bytecode pipelines (kotlinc / javac / R8 /
#                     desugar) on Android. Everything iOS compiles
#                     is native code — Swift, Obj-C, C and C++ all
#                     flow through clang/swiftc into the Mach-O.
#   native_ms       → Swift + Obj-C + C/C++ compile units, Swift
#                     module planning / emission / clang module
#                     building. Dominates almost every iOS build.
#                     Matches the Android semantic (JNI/C++ compile
#                     via CMake / NDK lands in `native_ms` there).
#   resources_ms    → asset catalogs, storyboards, xibs, strings,
#                     plist processing, resource copies.
#   packaging_ms    → linking, code signing, framework embedding,
#                     strip, touch, dSYM generation, Swift stdlib
#                     embedding (conceptually "get the runtime into
#                     the bundle").
#   other_ms        → build-graph dependency computation, tool
#                     version discovery, auxiliary file generation,
#                     Swift Package Manager resolution steps — the
#                     scaffolding that isn't otherwise classified.
#                     Typically <1% on a simple app build; SPM-heavy
#                     projects can push this higher as `Computing
#                     package information` / `Copying Package.resolved`
#                     / `Resolve Package Graph` all land in this
#                     bucket.
#
# Wrapper prefixes filter FIRST so container sections contribute to
# no category; within the remaining rules, precedence is native →
# resources → packaging (each list is checked in order and the
# first match wins).
_XCACTIVITYLOG_CATEGORY_NATIVE_PATTERNS = (
    # Per-source compile events: "Compile Foo.swift (arm64)", etc.
    re.compile(r'^Compile \S+\.(swift|m|mm|c|cpp|cxx|cc)\b', re.IGNORECASE),
    re.compile(r'^CompileSwiftSources\b'),
    re.compile(r'^CompileC\b'),
    re.compile(r'^CompileSwift\b'),
    # Swift toolchain phases — planning / driver / module emission.
    re.compile(r'^Planning Swift module\b'),
    re.compile(r'^SwiftDriver\b'),
    re.compile(r'^Emit(?:ting)? [Ss]wift [Mm]odule\b'),
    re.compile(r'^Emitting module for\b'),
    re.compile(r'^SwiftMergeGeneratedHeaders\b'),
    re.compile(r'^SwiftVerifyEmittedModuleInterface\b'),
    re.compile(r'^Generate Swift Constant Values\b'),
    # Explicit module / Clang module builds pulled into Swift.
    # NOTE: `^Compiling Clang module` is also special-cased in
    # `_classify_section_title` ahead of the wrapper check — the
    # `Compiling ` wrapper prefix would otherwise intercept it.
    re.compile(r'^Compiling Clang module\b'),
    re.compile(r'^Precompile module\b'),
    re.compile(r'^Explicitly Built\b'),
    re.compile(r'^Discovering version info for swiftc\b'),
    re.compile(r'^Extract app intents metadata\b', re.IGNORECASE),
)
_XCACTIVITYLOG_CATEGORY_RESOURCES_PATTERNS = (
    re.compile(r'^Compile asset catalog', re.IGNORECASE),
    re.compile(r'^CompileAssetCatalog\b'),
    re.compile(r'^CompileStoryboard\b'),
    re.compile(r'^CompileXIB\b'),
    re.compile(r'^CompileXCStrings\b'),
    # `LinkStoryboards` must be caught here, before the packaging
    # tuple's generic `^Link\b` rule claims it. The native →
    # resources → packaging precedence in `_classify_section_title`
    # is what keeps this working — do not reorder.
    re.compile(r'^LinkStoryboards\b'),
    re.compile(r'^CompileStrings\b'),
    re.compile(r'^ProcessInfoPlistFile\b'),
    re.compile(r'^CpResource\b'),
    re.compile(r'^CopyPlistFile\b'),
    re.compile(r'^CopyStringsFile\b'),
    re.compile(r'^CopyTiffFile\b'),
    re.compile(r'^CopyPNGFile\b'),
    re.compile(r'^GenerateAssetSymbols\b'),
)
_XCACTIVITYLOG_CATEGORY_PACKAGING_PATTERNS = (
    re.compile(r'^Link\b'),
    re.compile(r'^Ld\b'),
    re.compile(r'^CodeSign\b'),
    re.compile(r'^Sign \b'),
    re.compile(r'^SignManifestFile\b'),
    re.compile(r'^Strip\b'),
    re.compile(r'^Touch\b'),
    re.compile(r'^Embed\b'),
    re.compile(r'^ProcessProductPackaging\b'),
    re.compile(r'^RegisterExecutionPolicyException\b'),
    re.compile(r'^Validate\b'),
    re.compile(r'^GenerateDSYMFile\b'),
    re.compile(r'^CreateUniversalBinary\b'),
    # Swift stdlib embedding — `swift-stdlib-tool` copies the Swift
    # runtime dylibs into the app bundle. Conceptually packaging,
    # not compilation.
    re.compile(r'^Copy Swift standard libraries\b'),
)


def _find_derived_data_root(obj_root):
    """Walk up from `$OBJROOT` looking for the first ancestor that has
    a `Logs/Build/` subdirectory — that's Xcode's per-project
    DerivedData root. Returns the path, or None when not found.

    `$OBJROOT` during `archive` typically resolves to
    `<DerivedData>/Build/Intermediates.noindex/ArchiveIntermediates/
    <SchemeName>/IntermediateBuildFilesPath`, so the ancestor walk
    usually crosses four or five directory levels before hitting the
    logs folder. Bounded by an explicit step cap so a malformed
    `$OBJROOT` never sends us walking to `/`.
    """
    if not obj_root:
        return None
    current = os.path.normpath(obj_root)
    for _ in range(10):
        candidate = os.path.join(current, 'Logs', 'Build')
        if os.path.isdir(candidate):
            return current
        parent = os.path.dirname(current)
        if parent == current:
            return None
        current = parent
    return None


def _find_latest_xcactivitylog(obj_root):
    """Return the path to the newest `.xcactivitylog` Xcode wrote for
    this project, or None if the log directory can't be located.

    "Newest" is resolved by mtime — Xcode writes one log file per
    build/archive, so the most-recently-modified one in `Logs/Build/`
    corresponds to the archive we're currently running under.

    TODO(timings): Multi-arch archives (Mac Catalyst, iOS + macOS
    targets in one workspace) can place the relevant log in a sibling
    `Logs/Build/` directory we don't search. The current
    newest-mtime-in-the-discovered-dir strategy is deterministic but
    may pick the wrong arch's log on such projects. Cross-directory
    search deferred.

    TODO(timings): Stale-log detection — if the newest `.xcactivitylog`
    was written before the current build started, we'd report
    pre-build numbers as if they were this build's. No retry / warning
    is emitted today; consider checking the file's mtime against
    `os.environ.get('BUILD_TIMESTAMP')` or similar before parsing.
    """
    dd_root = _find_derived_data_root(obj_root)
    if not dd_root:
        return None
    log_dir = os.path.join(dd_root, 'Logs', 'Build')
    try:
        entries = [
            os.path.join(log_dir, f)
            for f in os.listdir(log_dir)
            if f.endswith('.xcactivitylog')
        ]
    except OSError:
        return None
    if not entries:
        return None
    # Tie-break by filename so sibling logs with the same
    # second-granularity mtime (HFS+ filesystems, rsync-preserving-
    # mtime CI caches) don't shuffle non-deterministically. Xcode
    # encodes a monotonic timestamp at the start of each log's
    # UUID-based filename, so descending-by-name pairs well with
    # descending-by-mtime.
    entries.sort(
        key=lambda p: (os.path.getmtime(p), os.path.basename(p)),
        reverse=True,
    )
    return entries[0]


def _tokenize_slf(data):
    """Tokenize an `SLF0` byte stream into a flat `[(type, value), …]`
    list. `data` is the DECOMPRESSED stream (the leading 4-byte `SLF0`
    header is skipped here).

    Each token is `<ascii-payload><1-byte-delimiter>`:
      - `"` / `%` / `*` are LENGTH-PREFIXED: the payload is a DECIMAL
        length, then that many raw bytes follow and become the token's
        value (decoded as UTF-8, replacement on error). The single
        nastiest bug here is that the length is DECIMAL, NOT hex, and
        that `*` (JSON/data blob) MUST consume its length in bytes or
        the whole stream desyncs.
      - `^` is a double: 16 hex chars, little-endian IEEE-754. Value is
        the float, or None if malformed.
      - `#` / `@` are ints: HEX payload. `#` is a plain int, `@` is a
        1-based class-table reference. Value is the parsed int.
      - `(` is an array/object header: HEX payload is the element
        count. Value is that int.
      - `-` is null. Value is None.

    Returns `(tokens, desync_count)`. `desync_count` is the number of
    malformed length/number payloads encountered — non-zero hints the
    grammar drifted, but parsing continues best-effort.
    """
    tokens = []
    desync = 0
    i = 4  # skip the 4-byte 'SLF0' header
    n = len(data)
    payload = bytearray()
    while i < n:
        b = data[i]
        if b in _SLF_DELIMS:
            t = chr(b)
            p = payload.decode('ascii', 'replace')
            payload = bytearray()
            i += 1
            if b in _SLF_LEN_PREFIXED_SET:
                # DECIMAL length, then that many raw bytes.
                try:
                    ln = int(p, 10) if p else 0
                except ValueError:
                    ln = 0
                    desync += 1
                tokens.append((t, data[i:i + ln].decode('utf-8', 'replace')))
                i += ln
            elif t == '^':
                if len(p) == 16:
                    try:
                        tokens.append((t, struct.unpack('<d', bytes.fromhex(p))[0]))
                    except Exception:
                        tokens.append((t, None))
                        desync += 1
                else:
                    tokens.append((t, None))
            else:
                # '#', '@', '(' carry a HEX payload; '-' carries none.
                try:
                    tokens.append((t, int(p, 16) if p else 0))
                except ValueError:
                    tokens.append((t, None))
                    desync += 1
        else:
            payload.append(b)
            i += 1
    return tokens, desync


def _extract_slf_sections(tokens):
    """Walk a tokenized SLF stream and extract every section instance
    as a `(cls, title, start_cf, end_cf)` tuple.

    The class table is every `%` className-def in stream order, 1-based;
    an `@N` token references the N-th def. A section instance starts at
    an `@`-ref to one of the two section classes, immediately followed
    by tokens of types `# " " " ^ ^` (sectionType, domainType, title,
    signature, timeStarted, timeStopped) and then a subSections field
    that is `(` (array) or `-` (none). We read:
      - `cls`      — the referenced class name.
      - `title`    — the 3rd string (index +3).
      - `start_cf` — the 1st double (index +5), CFAbsoluteTime seconds.
      - `end_cf`   — the 2nd double (index +6), CFAbsoluteTime seconds.

    Sections with a missing / non-finite / inverted timestamp pair are
    dropped (they can't contribute to span, occupancy, or the Gantt).

    No tree reconstruction is attempted: containment is resolved later
    by interval math, which is robust to the subSection-count drift
    that an explicit child-count stack walk is prone to on real logs.
    """
    class_table = [v for (t, v) in tokens if t == '%']
    ntok = len(tokens)

    def class_of(idx):
        if isinstance(idx, int) and 1 <= idx <= len(class_table):
            return class_table[idx - 1]
        return None

    sections = []
    for k in range(ntok - 7):
        t, v = tokens[k]
        if t != '@':
            continue
        cls = class_of(v)
        if cls not in _SLF_SECTION_CLASSES:
            continue
        # Shape check: # " " " ^ ^ then ( or - .
        if (tokens[k + 1][0] != '#' or tokens[k + 2][0] != '"'
                or tokens[k + 3][0] != '"' or tokens[k + 4][0] != '"'
                or tokens[k + 5][0] != '^' or tokens[k + 6][0] != '^'
                or tokens[k + 7][0] not in ('(', '-')):
            continue
        title = tokens[k + 3][1]
        start_cf = tokens[k + 5][1]
        end_cf = tokens[k + 6][1]
        if start_cf is None or end_cf is None:
            continue
        if not (math.isfinite(start_cf) and math.isfinite(end_cf)):
            continue
        if end_cf < start_cf:
            continue
        sections.append((cls, title, start_cf, end_cf))
    return sections


def _interval_union_seconds(intervals):
    """Total length (seconds) of the UNION of `[start, end]` intervals
    — the OCCUPANCY metric. Overlapping windows are merged, so the
    result can never exceed wall-clock. This is the fix for the flat
    code's per-category SUM, which double-counted Swift batch windows
    replicated onto every file's command section.

    `intervals` is an iterable of `(start, end)` float pairs (any
    order). Returns 0.0 for an empty input.
    """
    ordered = sorted(intervals)
    total = 0.0
    cur_start = cur_end = None
    for s, e in ordered:
        if cur_start is None:
            cur_start, cur_end = s, e
        elif s <= cur_end:
            if e > cur_end:
                cur_end = e
        else:
            total += cur_end - cur_start
            cur_start, cur_end = s, e
    if cur_start is not None:
        total += cur_end - cur_start
    return total


def _classify_section_title(title):
    """Map a command-invocation section title to one of the cross-
    platform category buckets: `'native'`, `'resources'`,
    `'packaging'`, `'other'`. (iOS never emits `'managed_code'` — see
    the mapping docstring above the pattern tuples.) Returns `None`
    only for an empty title. Precedence-ordered regex scan — first
    match wins.

    Callers pass COMMAND-invocation titles (`IDEActivityLogCommand-
    InvocationSection`), never the grouping wrappers, so there is no
    longer a wrapper-title escape hatch here: the SLF section-tree
    walk already separates the two classes, and per-category OCCUPANCY
    (interval union over command sections) is what feeds the chips,
    so a parallel build's occupancy can never exceed wall-clock
    `total_ms`. The dominant-category logic in `_build_timeline_blob`
    reuses this same classifier on the commands contained within each
    target window.
    """
    if not title:
        return None
    # `Compiling Clang module <name>` is a real native compile event
    # (explicit module build); list it ahead of the generic patterns
    # so it lands in `native` rather than `other`.
    if title.startswith('Compiling Clang module'):
        return 'native'
    for p in _XCACTIVITYLOG_CATEGORY_NATIVE_PATTERNS:
        if p.match(title):
            return 'native'
    for p in _XCACTIVITYLOG_CATEGORY_RESOURCES_PATTERNS:
        if p.match(title):
            return 'resources'
    for p in _XCACTIVITYLOG_CATEGORY_PACKAGING_PATTERNS:
        if p.match(title):
            return 'packaging'
    return 'other'


# `/Users/<name>` matches the username token regardless of what
# follows. Earlier we anchored on `(?=/|$)` so the lookahead would
# require either a path separator or end-of-string — but Xcode
# occasionally embeds bare user-home references in the middle of
# titles (e.g. `"warning at /Users/alice and exit"`), and the
# anchored form let the username slip past, where the catch-all
# `_ABSOLUTE_PATH_RE` then reduced `/Users/alice` to basename
# `alice` — emitting the bare username as a standalone word.
#
# Username character class is restricted to `[A-Za-z0-9._\-]+` (the
# realistic Unix-username surface) rather than `[^/\s]+`. The broader
# negation would also consume trailing punctuation (`,`, `)`, `:`,
# `;`, `.`) when the username appears mid-title, producing slightly
# mangled surrounding text in the emitted name. The narrower class
# stops at the first non-username character so the surrounding
# sentence preserves its shape (`"see /Users/alice)"` →
# `"see <home>)"`, not `"see <home>"`).
_PATH_USER_HOME_RE = re.compile(r'/Users/[A-Za-z0-9._\-]+')
_PATH_PRIVATE_VAR_FOLDERS_RE = re.compile(
    r'/private/var/folders/[^\s]+'
)
_ABSOLUTE_PATH_RE = re.compile(r'(?<!\S)(/[^\s]+)')


def _sanitize_section_title_for_emission(title):
    """Strip PII (username, machine-local paths) out of an xcactivitylog
    section title before it ships in `top_tasks`.

    Xcode often embeds absolute paths in section titles (e.g.
    `Compile /Users/alice/Projects/MyApp/Sources/Foo.swift`). We:
      - replace `/Users/<name>/` with `<home>/` (drops the username),
      - collapse `/private/var/folders/...` paths to their basename
        (TemporaryItems / DerivedData scratch paths leak machine UUIDs),
      - reduce any other absolute path token to its basename.
    Non-path tokens pass through unchanged so titles like
    `Compile Foo.swift (arm64)` are emitted verbatim.
    """
    if not title:
        return title

    def _replace_user_home(m):
        return '<home>'

    def _replace_private_var(m):
        return os.path.basename(m.group(0))

    def _replace_absolute(m):
        path = m.group(1)
        if path.startswith('<home>'):
            return path
        return os.path.basename(path) or path

    sanitized = _PATH_USER_HOME_RE.sub(_replace_user_home, title)
    sanitized = _PATH_PRIVATE_VAR_FOLDERS_RE.sub(_replace_private_var, sanitized)
    sanitized = _ABSOLUTE_PATH_RE.sub(_replace_absolute, sanitized)
    return sanitized


def _dominant_category_for_window(commands, win_start, win_end):
    """Return the DOMINANT category for a target window — the category
    with the greatest command-OCCUPANCY (interval union, not sum) among
    the command-invocations whose `[start, end]` is CONTAINED within
    `[win_start, win_end]`.

    Containment (rather than overlap) keeps each command attributed to
    exactly the target it belongs to; a command that straddles a target
    boundary (rare, and usually a build-system bookkeeping section) is
    simply not counted toward that target's category.

    `commands` is a list of `(category, start_cf, end_cf)` tuples for
    every classified command-invocation in the build. Returns `'native'`
    when the window contains no classifiable command (a target made up
    of only build-graph bookkeeping still renders as a native bar rather
    than vanishing).
    """
    by_cat = {}
    for cat, s, e in commands:
        if s >= win_start and e <= win_end:
            by_cat.setdefault(cat, []).append((s, e))
    if not by_cat:
        return 'native'
    best_cat = 'native'
    best_occ = -1.0
    for cat, intervals in by_cat.items():
        occ = _interval_union_seconds(intervals)
        if occ > best_occ:
            best_occ = occ
            best_cat = cat
    return best_cat


def _build_timeline_blob(targets, build_start_cf):
    """Build the Gantt-chart DETAIL blob from the per-target grouping
    records. `targets` is a list of `(path, category, start_cf, end_cf)`
    tuples — one per `Build target ` grouping, with `category` already
    resolved to the target's DOMINANT command-category — and
    `build_start_cf` is the build's earliest section start in
    CFAbsoluteTime.

    Wire shape (unchanged from the flat implementation, and mirroring
    the Android Gradle plugin's `TimingsPayloadSerializer` so back-end
    + front-end render both platforms from one schema):

      { "schema_version": 1,
        "build_started_at_ms": <epoch ms of build start>,
        "wall_clock_ms": <max end − min start over targets, ms>,
        "tasks": [ {"path", "category", "start_ms", "end_ms"}, … ] }

    Rules:
      - `start_ms`/`end_ms` are OFFSETS from `build_started_at_ms`
        (not absolute), in ms.
      - tasks sorted by `start_ms` ascending.
      - capped at `_TIMELINE_MAX_TASKS`; when truncating we keep the
        SLOWEST targets, then re-sort the kept slice by start.

    Unlike the old code, the rows are the per-target GROUPINGS — NOT
    per-file leaf sections — so the Gantt shows ~one bar per target
    (low-double-digit peak concurrency) rather than 300+ phantom
    parallel bars. The mega-wrappers (root build / `Prepare build` /
    `Run post-actions` / `Prepare packages`) were already filtered out
    by the caller.

    Returns the blob dict, or None when there are no target groupings —
    callers then PUT nothing.
    """
    if not targets:
        return None

    # `build_started_at_ms` is anchored to the WHOLE build's start (the
    # earliest section of any class), so per-target offsets are relative
    # to t0 of the build, not to the earliest target.
    build_started_at_ms = int(round(
        (build_start_cf + _CF_ABSOLUTE_TIME_EPOCH_OFFSET) * 1000))
    latest_end_cf = max(e for _p, _c, _s, e in targets)
    wall_clock_ms = max(0, int(round((latest_end_cf - build_start_cf) * 1000)))

    # Truncation keeps the SLOWEST targets (sort by duration desc,
    # slice), then re-sorts the kept slice chronologically so the array
    # reads start-ordered for the front-end's greedy-lane Gantt packer.
    if len(targets) > _TIMELINE_MAX_TASKS:
        print(
            "Bugsee: build-timings detail blob truncated "
            "(%d targets -> %d slowest kept)"
            % (len(targets), _TIMELINE_MAX_TASKS)
        )
        kept = sorted(
            targets, key=lambda t: t[3] - t[2], reverse=True
        )[:_TIMELINE_MAX_TASKS]
    else:
        kept = targets

    tasks = [
        {
            'path': _sanitize_section_title_for_emission(path)[:255],
            'category': category,
            'start_ms': int(round((start_cf - build_start_cf) * 1000)),
            'end_ms': int(round((end_cf - build_start_cf) * 1000)),
        }
        for path, category, start_cf, end_cf in sorted(kept, key=lambda t: t[2])
    ]

    return {
        'schema_version': _TIMELINE_SCHEMA_VERSION,
        'build_started_at_ms': build_started_at_ms,
        'wall_clock_ms': wall_clock_ms,
        'tasks': tasks,
    }


def _timeline_blob_gz(blob):
    """Gzip the compact JSON timeline blob, mirroring `_deps_blob_gz`
    (compact separators, `gzip.compress`). Shape matches the Android
    Gradle plugin's `TimingsPayloadSerializer.gzipBytes`."""
    raw = json.dumps(blob, separators=(',', ':')).encode('utf-8')
    return gzip.compress(raw)


def _parse_xcactivitylog(log_path):
    """Extract the build's wall-clock span, per-category OCCUPANCY, a
    top-N slowest-targets list, AND a per-target Gantt timeline from an
    `.xcactivitylog`, using a proper SLF section-tree decode.

    Pipeline:
      1. Decompress + `_tokenize_slf` the `SLF0` stream.
      2. `_extract_slf_sections` → every `(cls, title, start, end)`
         section instance, split into the two section classes.
      3. `total_ms`      = wall-clock SPAN (`max(end) − min(start)`)
                           over ALL sections.
      4. `category_sums` = per-category OCCUPANCY (interval union) over
                           the COMMAND-invocation sections, classified
                           by title. Occupancy can never exceed
                           wall-clock — the fix for the flat code's
                           batch-inflated SUMs.
      5. targets         = the `IDEActivityLogSection` groupings whose
                           title starts with `Build target ` (the
                           mega-wrappers are excluded). Each target's
                           DOMINANT category is the category with the
                           greatest command-occupancy among commands
                           contained within its window.
      6. `top_tasks`     = the slowest targets (name + duration_ms),
                           capped at `_XCACTIVITYLOG_TOP_N`.
      7. `timeline`      = the Gantt blob (one row per target).

    Returns a dict with `total_ms` / `top_tasks` / `category_sums` /
    `timeline`, or None when the log can't be opened / decompressed /
    tokenized into any section at all.
    """
    try:
        with gzip.open(log_path, 'rb') as g:
            data = g.read(_XCACTIVITYLOG_MAX_DECOMPRESSED + 1)
    except Exception:
        return None

    if len(data) > _XCACTIVITYLOG_MAX_DECOMPRESSED:
        # Truncated to cap memory; a truncated tail loses late sections
        # anyway. Work with what we have — the class table and the root
        # section live at the head of the stream.
        data = data[:_XCACTIVITYLOG_MAX_DECOMPRESSED]

    tokens, _desync = _tokenize_slf(data)
    sections = _extract_slf_sections(tokens)
    if not sections:
        return None

    # total_ms = wall-clock SPAN over ALL sections. CFAbsoluteTime is
    # seconds since 2001; the span is offset-independent so no epoch
    # shift is needed here.
    build_start_cf = min(s for _c, _t, s, _e in sections)
    build_end_cf = max(e for _c, _t, _s, e in sections)
    total_ms = max(0, int(round((build_end_cf - build_start_cf) * 1000)))

    # Classify each COMMAND-invocation once; reused for both the
    # category-occupancy chips and the per-target dominant category.
    commands = []
    for cls, title, s, e in sections:
        if cls != _SLF_COMMAND_CLASS:
            continue
        bucket = _classify_section_title(title)
        if bucket is None:
            continue
        commands.append((bucket, s, e))

    # Per-category OCCUPANCY (interval union per bucket), in ms.
    # `managed_code` is a cross-platform bucket iOS never fills (Swift /
    # Obj-C / C/C++ all land in `native`); kept pre-seeded to zero for
    # parity with Android, and the emission loop drops zero buckets.
    by_cat_intervals = {}
    for bucket, s, e in commands:
        by_cat_intervals.setdefault(bucket, []).append((s, e))
    category_sums = {
        'managed_code': 0,
        'native': 0,
        'resources': 0,
        'packaging': 0,
        'other': 0,
    }
    for bucket, intervals in by_cat_intervals.items():
        category_sums[bucket] = int(round(
            _interval_union_seconds(intervals) * 1000))

    # `Build target ` groupings → the Gantt rows + top_tasks. The four
    # mega-wrappers (root build, `Prepare build`, `Prepare packages`,
    # `Run post-actions`) are `IDEActivityLogSection` too but DON'T
    # carry the `Build target ` prefix, so they're excluded — they span
    # the whole build and would draw a single full-width bar.
    targets = []
    for cls, title, s, e in sections:
        if cls != _SLF_SECTION_CLASS:
            continue
        if not title or not title.startswith(_XCACTIVITYLOG_TARGET_PREFIX):
            continue
        category = _dominant_category_for_window(commands, s, e)
        # Strip the `Build target ` prefix for the emitted path.
        path = title[len(_XCACTIVITYLOG_TARGET_PREFIX):] or title
        targets.append((path, category, s, e))

    # top_tasks = slowest target groupings, longest first, capped at
    # TOP_N. Durations here are the target wall-clock windows (NOT
    # batch-inflated per-file sums).
    top_sorted = sorted(
        targets, key=lambda t: t[3] - t[2], reverse=True)
    top_tasks = []
    for path, _category, s, e in top_sorted[:_XCACTIVITYLOG_TOP_N]:
        dur = int(round((e - s) * 1000))
        if dur < 1:  # sub-millisecond targets are noise
            continue
        top_tasks.append({
            'name': _sanitize_section_title_for_emission(path)[:255],
            'duration_ms': dur,
        })

    # Per-target Gantt blob. Offsets are relative to the WHOLE build's
    # start so the bars line up with the absolute timeline.
    timeline = _build_timeline_blob(targets, build_start_cf)

    return {
        'total_ms': total_ms,
        'top_tasks': top_tasks,
        'category_sums': category_sums,
        'timeline': timeline,
    }


def resolve_build_timings(env):
    """Produce the build's timing data for the current build.

    Returns a `(timings, timeline_gz)` tuple:
      - `timings`: the inline `build_metadata.timings` sub-object —
        `total_ms` (wall-clock SPAN), a `top_tasks` list of the
        slowest `Build target ` groupings, and a per-category rollup
        (`native_ms` / `resources_ms` / `packaging_ms` / `other_ms`)
        whose values are command-invocation OCCUPANCY (interval union,
        so they never exceed `total_ms`). iOS never emits
        `managed_code_ms` — Swift / Obj-C / C / C++ all compile into
        the Mach-O and land in `native_ms`. The server schema shares
        the field names with Android, which keeps `managed_code_ms`
        populated (JVM-bytecode compilation: kotlinc / javac / R8 /
        desugar).
      - `timeline_gz`: the gzipped per-target Gantt DETAIL blob PUT to
        the presigned `timings_upload_endpoint` for Gantt-chart parity
        with Android's `timings.json`, or None when there's no
        `Build target ` grouping to chart.

    Either element may be None independently. `(None, None)` means no
    timing source was available at all.

    Wraps the entire pipeline in a broad except so any future parser
    bug (e.g. an `inf`/`nan` slipping past the section filters and
    overflowing duration arithmetic, or a malformed SLF stream
    causing struct/unicode decode errors that weren't anticipated)
    degrades gracefully to "no timings" instead of escaping into the
    outer build-publish wrapper. The outer wrapper aborts the entire
    build-info upload — losing timings is acceptable; losing the
    build record is not.
    """
    try:
        return _resolve_build_timings_impl(env)
    except Exception as e:
        print(
            "Bugsee: build-timings extraction failed (%s) — "
            "omitting timings from build_metadata" % str(e)
        )
        return None, None


def _resolve_build_timings_impl(env):
    obj_root = env.get('OBJROOT')
    log_path = _find_latest_xcactivitylog(obj_root)
    if not log_path:
        return None, None
    parsed = _parse_xcactivitylog(log_path)
    if not parsed:
        return None, None

    # Server sanitizer drops fields that are falsy / None, but being
    # explicit about omissions keeps the wire payload tidy. Emit
    # zero-valued category sums as positive zeros so "no data" stays
    # distinguishable from "genuinely zero time in this category" on
    # the server — the sanitizer preserves zero-valued ints.
    timings = {}
    if parsed.get('total_ms'):
        timings['total_ms'] = parsed['total_ms']
    if parsed.get('top_tasks'):
        timings['top_tasks'] = parsed['top_tasks']
    for bucket, value in (parsed.get('category_sums') or {}).items():
        if value > 0:
            timings['%s_ms' % bucket] = value

    # Per-task timeline DETAIL blob — gzipped only when it carries at
    # least one task, so the caller never sets `request_timings_upload`
    # nor PUTs an empty blob. Mirrors the deps-blob "summary + blob"
    # split exactly.
    timeline = parsed.get('timeline')
    timeline_gz = None
    if timeline and timeline.get('tasks'):
        timeline_gz = _timeline_blob_gz(timeline)

    return (timings or None), timeline_gz


# -----------------------------------------------------------------
# Build-publish flow + gate
# -----------------------------------------------------------------
#
# The flow has two layers:
#
#   - **build-info** (default ON, release-only): every Release archive
#     posts a build record to the Bugsee back-end carrying version,
#     build, package_id, VCS, build-machine, plugin / Xcode / SDK
#     versions, timings, and the artefact's file size. The record
#     unlocks crash-context enrichment (commit lookup) and serves as
#     the in-build size-check baseline. Disable via
#     `BUGSEE_BUILD_INFO_ENABLED=0` for firewalled CI / privacy-
#     sensitive builds.
#
#   - **size-analysis** (default OFF, sub-feature of build-info):
#     when enabled, the build-info POST also asks the server for a
#     presigned PUT URL and ships the artefact bytes for server-side
#     tree analysis. Requires build-info to be enabled — the flow
#     warns and skips both if size-analysis is on while build-info
#     is off.


def _env_truthy_default_true(value):
    """`True` for missing / unset / empty values (treated as "default
    on") AND for conventional truthy tokens. Used by the build-info
    gate where the default is ON.

    Empty string is treated as missing: many GUIs (Xcode's "Add
    Environment Variable", some CI dashboards) emit `BUGSEE_…=""`
    when the user leaves the value field blank. Treating `""` as
    "off" would silently flip a user who *thought* they were
    accepting the default into the disabled path — confusing and
    invisible."""
    if value is None:
        return True
    if not value.strip():
        return True
    return _env_truthy(value)




def main():
    # Symbols-pipeline entry. The deps pipeline is now invoked
    # separately from the post-daemonization slot at module level
    # (see the `if __name__ == "__main__":` block) so it runs
    # regardless of whether the build has dSYM symbols to upload.
    #
    # As of the bugsee-cli migration, the actual dSYM upload is
    # performed by the bugsee-cli Rust binary, one invocation per
    # `.dSYM` bundle. This loop's role is:
    #   - discover .dSYM bundles under options.dsym_folder
    #   - extract Mach-O UUIDs (via dwarfdump) to short-circuit
    #     dSYMs whose UUIDs are already in ~/.bugseeUploadList
    #   - apply BCSymbolMap deobfuscation in place when --maps is set
    #   - hand each surviving .dSYM directory to the CLI
    # The CLI itself re-extracts UUIDs internally via
    # `symbolic-debuginfo` and POSTs `{version, build}` to
    # /apps/<token>/symbols — the server then walks the uploaded
    # tarball and stores `images[]` per arch slice. Dashboard
    # outcome is one symbol record per .dSYM (finer granularity
    # than the legacy one-record-per-build zip).
    tempDir = tempfile.mkdtemp()
    print("Processing in " + tempDir)
    # List of (dsym_bundle_dir, uuids_discovered) — one entry per
    # .dSYM the CLI needs to upload.
    dsymUploads = []
    uploadedImages = loadUploadedList()

    # Track the first .dSYM zip filename (--list mode) so the legacy
    # `-{version}-{build}.dSYM.zip` pattern can supply the version/build
    # fallback. Used only when neither --version/--build nor Info.plist
    # produced values.
    firstDsymZipForFallback = None
    if options.dsym_list:
        options.dsym_folder = tempDir
        for f in args[1:]:
            if (os.path.islink(f)):
                continue
            if (os.stat(f).st_size == 0):
                continue
            if firstDsymZipForFallback is None:
                firstDsymZipForFallback = f
            with zipfile.ZipFile(f, 'r') as zipf:
                zipf.extractall(tempDir)

    # Resolve version + build with the legacy fallback chain. Order:
    #   1. --version / --build CLI flags (or BUGSEE_APP_{VERSION,BUILD} env)
    #   2. --list mode: `-{version}-{build}.dSYM.zip` filename pattern
    #   3. Otherwise: CFBundleShortVersionString + CFBundleVersion from
    #      $INFOPLIST_PATH (the Xcode build-phase default — users rarely
    #      pass -v/-b in that context).
    # Without resolved values the bugsee-cli exec would error out, since
    # `--version` and `--build` are required positional args on the CLI.
    resolvedVersion = options.version
    resolvedBuild = options.build
    if not (resolvedVersion and resolvedBuild):
        fallbackVersion, fallbackBuild = getVersionAndBuild(firstDsymZipForFallback or "")
        if not resolvedVersion:
            resolvedVersion = fallbackVersion
        if not resolvedBuild:
            resolvedBuild = fallbackBuild

    os.chdir(options.dsym_folder)
    for root, dirs, files in os.walk(options.dsym_folder):
        if not root.endswith('dSYM/Contents/Resources/DWARF'):
            continue

        # The .dSYM directory is three components up from
        # `<bundle>.dSYM/Contents/Resources/DWARF`.
        dsymDir = os.path.dirname(os.path.dirname(os.path.dirname(root)))
        print(root)

        newImagesInDsym = []
        for f in files:
            filePath = os.path.join(root, f)
            if os.path.islink(filePath):
                continue
            if os.stat(filePath).st_size == 0:
                continue
            images = parseDSYM(filePath)
            if len(images) == 0:
                continue
            if isInUploadedList(images, uploadedImages):
                print("Already uploaded %s, skipping" % f)
                continue
            if options.symbol_maps:
                deobfuscateDSYM(filePath, options.symbol_maps)
            newImagesInDsym.extend(images)

        if newImagesInDsym:
            dsymUploads.append((dsymDir, newImagesInDsym))

    if len(dsymUploads) > 0:
        if not (resolvedVersion and resolvedBuild):
            # CLI requires both. Bailing here avoids burning N CLI execs
            # only to have each fail the same way at argv parsing.
            print("Bugsee: could not determine version/build (none of "
                  "--version/--build, --list-mode filename pattern, or "
                  "$INFOPLIST_PATH produced values); %d dSYM(s) not "
                  "uploaded" % len(dsymUploads))
        else:
            cliBinary = resolveCli(
                cliPath=options.cli_path,
                cliVersion=options.cli_version)
            if cliBinary is None:
                # resolveCli already explained why on stderr/stdout. Skip
                # uploads; do NOT mark UUIDs as uploaded — next run will
                # retry once a usable binary is available.
                print("Bugsee: no bugsee-cli available; %d dSYM(s) not uploaded" % len(dsymUploads))
            else:
                successCount = 0
                for dsymDir, images in dsymUploads:
                    ok = uploadDsymViaCli(
                        cliBinary,
                        dsymDir,
                        APP_TOKEN,
                        options.endpoint,
                        resolvedVersion,
                        resolvedBuild,
                    )
                    if ok:
                        successCount += 1
                        uploadedImages.extend(images)
                if successCount > 0:
                    saveUploadedList(uploadedImages)
                print("Bugsee: uploaded %d/%d dSYM(s) via bugsee-cli" % (
                    successCount, len(dsymUploads)))

    # cleanup
    shutil.rmtree(tempDir, ignore_errors=True)


if __name__ == "__main__":
    usage = "usage: %prog [options] token [dsym1 dsym2 dsym3]"
    parser = OptionParser(usage=usage, description="Uploads symbol files to Bugsee server")
    parser.add_option("-e", "--endpoint", dest="endpoint",
                  help="Use custom API endpoint for uploading", default="https://api.bugsee.com")
    parser.add_option("-f", "--folder", dest="dsym_folder",
                  help="Use custom folder to scan for dSYMs", default=os.environ.get('DWARF_DSYM_FOLDER_PATH'))
    parser.add_option("-m", "--maps", dest="symbol_maps",
                  help="Use folder containing symbol maps to deobfuscate dSYM files")
    parser.add_option("-l", "--list", dest="dsym_list", action="store_true", default=False,
                  help="Use dsyms from the command line instead of parsing folder")
    parser.add_option("-x", "--external", dest="from_xcode", action="store_false", default=True,
                  help="The agent is being run not from XCode build phase")
    parser.add_option("-v", "--version", dest="version",
                  help="Set the version of the application dSYM corresponds to")
    parser.add_option("-b", "--build", dest="build",
                  help="Set the version of the application dSYM corresponds to")
    parser.add_option("-d", "--build_dir", dest="build_dir",
                  help="Use for custom TARGET_BUILD_DIR", default=os.environ.get('TARGET_BUILD_DIR'))
    # Dependencies-collection toggle. On by default — registers
    # the build with Bugsee and uploads a per-build deps blob
    # parsed from Podfile.lock / Package.resolved / Cartfile.resolved
    # / linked vendored frameworks. Disable with --no-deps if the
    # consumer wants the legacy symbols-only flow OR if the Bugsee
    # iOS SDK's tools.bundle/BugseeAgent build phase already
    # handled deps collection for this build (the fastlane Ruby
    # action checks the cross-producer handshake and passes
    # --no-deps when it detects the other producer did the work).
    parser.add_option("--no-deps", dest="collect_deps", action="store_false",
                  default=True,
                  help="Skip the dependencies collection + upload step. "
                       "Symbols + timings uploads still run unless "
                       "disabled separately.")
    # Timings-collection toggle. On by default. Independent of
    # --no-deps so the cross-producer handshake can disable each
    # action individually. When the Bugsee iOS SDK's
    # tools.bundle/BugseeAgent build phase already collected the
    # xcactivitylog-derived build timings for this build, the
    # fastlane Ruby action passes --no-timings here and the
    # build-info pipeline emits no `build_metadata.timings`
    # sub-object and skips the timings PUT.
    parser.add_option("--no-timings", dest="collect_timings",
                  action="store_false", default=True,
                  help="Skip the xcactivitylog-derived build timings "
                       "collection + upload step. Symbols + deps "
                       "uploads still run unless disabled separately.")
    # bugsee-cli override knobs. See the resolver block near the top of
    # this file for the full precedence rules.
    parser.add_option("--cli-path", dest="cli_path",
                  default=os.environ.get("BUGSEE_CLI_PATH"),
                  help="Path to a local bugsee-cli binary. When set and the file "
                       "is executable, this binary is used for symbol upload "
                       "instead of the auto-downloaded one. Lets developers test "
                       "a locally-built CLI without touching the on-disk cache.")
    parser.add_option("--cli-version", dest="cli_version",
                  default=os.environ.get("BUGSEE_CLI_VERSION"),
                  help="bugsee-cli version to auto-download when --cli-path is "
                       "unset. Defaults to BUGSEE_CLI_DEFAULT_VERSION (pinned to "
                       "the version this agent was shipped against).")
    parser.add_option("--project-root", dest="project_root",
                  default=os.environ.get('SRCROOT') or os.environ.get('PROJECT_DIR'),
                  help="Root of the iOS project — where lockfiles "
                       "(Podfile.lock / Package.resolved / Cartfile.resolved) "
                       "are searched for. Defaults to $SRCROOT then "
                       "$PROJECT_DIR when run from Xcode.")
    # ──────────────────────────────────────────────
    # Android mapping upload mode (off by default)
    # ──────────────────────────────────────────────
    # When --upload-mapping is passed, BugseeAgent skips ALL the
    # iOS-side flows (dSYM upload, dependencies pipeline,
    # daemonization, dSYM-folder scanning) and runs ONE step:
    # resolve bugsee-cli, upload the mapping.txt at --mapping-path
    # via `debug-files upload --type proguard --uuid <pre-resolved>`.
    # The fastlane plugin's upload_mapping_to_bugsee Ruby action
    # resolves the UUID upstream (from explicit override, the Bugsee
    # Gradle plugin's build-uuid.txt, or synthesis matching the
    # SDK's runtime fallback formula) and passes the pre-resolved
    # value via --mapping-uuid.
    parser.add_option("--upload-mapping", dest="upload_mapping",
                  action="store_true", default=False,
                  help="Run in Android mapping upload mode. Skips "
                       "iOS dSYM / deps flows entirely. Requires "
                       "--mapping-path, --mapping-uuid, --version, "
                       "--build, and the positional app token.")
    parser.add_option("--mapping-path", dest="mapping_path",
                  default=None,
                  help="Path to the Android mapping.txt to upload. "
                       "Only used with --upload-mapping.")
    parser.add_option("--mapping-uuid", dest="mapping_uuid",
                  default=None,
                  help="Pre-resolved BUILD_UUID for the mapping. "
                       "The fastlane action computes this Ruby-side "
                       "(from the Gradle plugin's build-uuid.txt or "
                       "by synthesis matching the SDK's runtime "
                       "fallback formula) so the SDK can match the "
                       "uploaded mapping against runtime crashes.")
    parser.add_option("--icon", dest="icon_path",
                  default=None,
                  help="Optional launcher-icon PNG path. Forwarded "
                       "to bugsee-cli's --icon flag for "
                       "--type proguard uploads.")
    parser.add_option("--upload-artifact", dest="upload_artifact",
                  action="store_true", default=False,
                  help="iOS artifact-upload flow. Packages the .app "
                       "at --app-path into a synthetic .ipa and "
                       "uploads it to the back-end for size analysis. "
                       "Short-circuits the dSYM / deps / timings "
                       "pipeline. Used by the upload_artifact_to_bugsee "
                       "fastlane action.")
    parser.add_option("--app-path", dest="app_path",
                  default=None,
                  help="Path to the built `.app` directory. Required "
                       "by --upload-artifact. Typically resolved by "
                       "the fastlane action from xcarchive_path + "
                       "Products/Applications/<App>.app or from "
                       "TARGET_BUILD_DIR/WRAPPER_NAME.")
    parser.add_option("--request-artifact-upload", dest="request_artifact_upload",
                  action="store_true", default=False,
                  help="Set the build registration payload's "
                       "`request_artifact_upload` field to true. "
                       "Implied by --upload-artifact; expose "
                       "separately so a future build-info-only "
                       "caller can request size analysis without "
                       "actually shipping the artefact bytes.")
    parser.add_option("--build-info-only", dest="build_info_only",
                  action="store_true", default=False,
                  help="Inverse of --request-artifact-upload. With "
                       "--upload-artifact, this flips the flow into "
                       "register-only mode: the registration POST "
                       "still records `artifact_size` on the server "
                       "(so the dashboard's size-trend chart works) "
                       "but the .ipa bytes never leave the build "
                       "host. Useful for firewalled CI and privacy-"
                       "sensitive setups.")
    (options, args) = parser.parse_args()

    # ──────────────────────────────────────────────
    # App-token check (BEFORE daemonization)
    # ──────────────────────────────────────────────
    # Pulled in front of the fork so a missing-token error reaches
    # the user's terminal / Xcode build log instead of being
    # swallowed by the daemonized child's redirected stdout.
    if (len(args) < 1):
        print("Bugsee:  Not initialized with app token. Must be passed as a parameter")
        exit(1)
    APP_TOKEN = args[0]

    # ──────────────────────────────────────────────
    # Android mapping upload — short-circuit path
    # ──────────────────────────────────────────────
    # Runs BEFORE the from_xcode daemonization fork so the
    # mapping upload is fully synchronous from the caller's
    # perspective (the Ruby action's Actions.sh shells to us and
    # blocks on completion). Skips:
    #   - the iOS dSYM upload flow (--type dsym is wrong for Android)
    #   - the iOS deps pipeline (Podfile.lock / Package.resolved /
    #     Cartfile.resolved scanning — irrelevant for an Android
    #     build's mapping.txt)
    #   - the daemonization double-fork (the iOS-specific Xcode-
    #     post-action runs out-of-process so it can't block the
    #     build; the fastlane Android lane WANTS to block).
    # The fastlane action's Ruby side handles UUID resolution and
    # input validation; here we just exec the CLI.
    if options.upload_mapping:
        if not options.mapping_path:
            print("Bugsee: --upload-mapping requires --mapping-path")
            exit(1)
        if not options.mapping_uuid:
            print("Bugsee: --upload-mapping requires --mapping-uuid "
                  "(fastlane-resolved BUILD_UUID for SDK matching)")
            exit(1)
        if not os.path.isfile(options.mapping_path):
            print("Bugsee: mapping file does not exist: %s"
                  % options.mapping_path)
            exit(1)
        if options.icon_path and not os.path.isfile(options.icon_path):
            print("Bugsee: --icon path does not exist: %s "
                  "(continuing without icon)" % options.icon_path)
            options.icon_path = None
        cliBinary = resolveCli(options.cli_path, options.cli_version)
        if not cliBinary:
            print("Bugsee: bugsee-cli unavailable; mapping upload skipped")
            exit(1)
        ok = uploadMappingViaCli(
            cliBinary, options.mapping_path, APP_TOKEN,
            options.endpoint, options.version, options.build,
            options.mapping_uuid, options.icon_path,
        )
        if ok:
            print("Bugsee: mapping uploaded successfully")
            exit(0)
        else:
            print("Bugsee: mapping upload failed")
            exit(1)

    # ──────────────────────────────────────────────
    # iOS artefact upload — short-circuit path
    # ──────────────────────────────────────────────
    # Runs BEFORE the from_xcode daemonization fork so the artefact
    # upload is fully synchronous from the caller's perspective (the
    # Ruby action's Actions.sh blocks on completion). Skips:
    #   - the iOS dSYM upload flow (orthogonal, has its own action)
    #   - the deps/timings pipeline (those have their own
    #     handshake-gated entry path)
    #   - the daemonization double-fork (the fastlane lane wants to
    #     block on the upload — the post-action daemon is an iOS
    #     SDK BugseeAgent-only concern)
    if options.upload_artifact:
        if not options.app_path:
            print("Bugsee: --upload-artifact requires --app-path")
            exit(1)
        if not os.path.isdir(options.app_path):
            print("Bugsee: --app-path does not exist or is not a "
                  "directory: %s" % options.app_path)
            exit(1)
        if not options.app_path.endswith('.app'):
            print("Bugsee: --app-path must end in .app: %s"
                  % options.app_path)
            exit(1)
        # `--build-info-only` flips the flow into register-only
        # mode (records artifact_size, ships no bytes). The agent's
        # default is byte-shipping (request_artifact_upload=True).
        ok = run_artifact_upload_flow(
            APP_TOKEN, options.endpoint, options.app_path,
            version=options.version,
            build_number=options.build,
            request_artifact_upload=not options.build_info_only,
        )
        if ok:
            print("Bugsee: artefact uploaded successfully")
            exit(0)
        else:
            print("Bugsee: artefact upload failed")
            exit(1)

    if options.from_xcode:
        # do the UNIX double-fork magic, see Stevens' "Advanced
        # Programming in the UNIX Environment" for details (ISBN 0201563177)
        try:
            pid = os.fork()
            if pid > 0:
                # exit first parent
                sys.exit(0)
        except OSError as e:
            print("fork #1 failed: %d (%s)" % (e.errno, e.strerror), file=sys.stderr)
            sys.exit(1)

        # decouple from parent environment
        os.chdir("/")
        os.setsid()
        os.umask(0)

        # do second fork
        try:
            pid = os.fork()
            if pid > 0:
                # exit from second parent, print eventual PID before
                print("Daemon PID %d" % pid)
                sys.exit(0)
        except OSError as e:
            print("fork #2 failed: %d (%s)" % (e.errno, e.strerror), file=sys.stderr)
            sys.exit(1)

        # redirect standard file descriptors
        outputFile = os.path.join(os.environ['PROJECT_TEMP_DIR'], "BugseeAgent.log")
        # this log will not show since xcode 10
        print("Detaching STDOUT, logs can be found in %s" % (outputFile))
        sys.stdout.flush()
        sys.stderr.flush()
        si = open("/dev/null", 'r')
        so = open(outputFile, 'w+')
        se = open("/dev/null", 'w')
        os.dup2(si.fileno(), sys.stdin.fileno())
        os.dup2(so.fileno(), sys.stdout.fileno())
        os.dup2(se.fileno(), sys.stderr.fileno())

    # ──────────────────────────────────────────────
    # Dependencies pipeline (runs in the daemonized child)
    # ──────────────────────────────────────────────
    #
    # Hoisted ABOVE the dSYM / simulator gates that follow because
    # the deps pipeline is independent of symbolication:
    #
    #   - Debug builds with `DEBUG_INFORMATION_FORMAT != dwarf-with-dsym`
    #     still ship their lockfile-derived dep list.
    #   - Simulator builds skip symbols but still get deps.
    #
    # Errors are caught and logged so a deps failure (parser bug,
    # network blip, ngrok tunnel down) cannot prevent the symbols
    # pipeline from running afterward — the two are independent.
    if options.collect_deps:
        try:
            _run_dependencies_pipeline(APP_TOKEN, options.project_root)
        except Exception as e:
            print("Bugsee: dependencies pipeline failed: %s — "
                  "continuing with symbols upload." % e)

    # ──────────────────────────────────────────────
    # Symbols-pipeline gates
    # ──────────────────────────────────────────────
    # Each gate exits the (already-daemonized) process cleanly so
    # the user's build log doesn't spam errors about dSYMs that
    # aren't supposed to exist on Debug / simulator builds. Deps
    # already ran above — these gates only short-circuit the
    # symbols half.
    if options.from_xcode:
        if os.environ.get('DEBUG_INFORMATION_FORMAT') != 'dwarf-with-dsym':
            print("Bugsee:  DEBUG_INFORMATION_FORMAT is not set. Have you enabled debug symbols in your build? See: https://docs.bugsee.com/sdk/ios/symbolication/")
            exit(0)

        if os.environ.get('EFFECTIVE_PLATFORM_NAME') == '-iphonesimulator':
            print("Bugsee:  Bugsee is not supoorted in iOS simulator. Will not upload debug symbols for i386!")
            exit(0)

    if not options.build_dir:
        print('Target build directory was not specified. Either provide it with the "-d" option or set "TARGET_BUILD_DIR" environment variable')
        exit(1)

    if options.dsym_list:
        dsym_list = args[1:]
        if len(dsym_list) < 1:
            print("Bugsee:  --list option is provided, but no dSYM files can be found in the command line")
            exit(1)
    else:
        if not options.dsym_folder:
            print("Bugsee:  Can not find dSYM folder (expecting either a -f option or DWARF_DSYM_FOLDER_PATH)")
            exit(1)

    # start the daemon main loop (symbols pipeline only)
    main()
