# ──────────────────────────────────────────────────────────────────
# bugsee-cli resolver
#
# Symbol upload (dSYM) is handled by the bugsee-cli Rust binary —
# the same one the Android Gradle plugin uses. This agent shells out
# to it instead of hand-rolling zip + curl. The binary is
# auto-downloaded from download.bugsee.com on first use, SHA-256
# verified, and cached under ~/.bugsee/cli/<version>/<triple>/.
# Override via --cli-path (developer-local binary) or --cli-version
# (test a newer release). Environment fallbacks: BUGSEE_CLI_PATH,
# BUGSEE_CLI_VERSION.
#
# Build-info / dependency collection (the rest of this file below)
# is still done in Python here. That migration is deferred to the
# cross-platform build-info contributor SPI.
# ──────────────────────────────────────────────────────────────────

BUGSEE_CLI_DEFAULT_VERSION = "0.1.1"
BUGSEE_CLI_DOWNLOAD_BASE = "https://download.bugsee.com/cli"
# Strict version-string shape: SemVer-ish `<major>.<minor>.<patch>`
# optionally followed by `-<prerelease>`. This regex gates any value
# that flows into the download URL or the on-disk cache directory
# path, so a malicious BUGSEE_CLI_VERSION env var cannot inject `/` or
# `..` segments to escape the cache root or redirect downloads.
_BUGSEE_CLI_VERSION_RE = re.compile(r'^[0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9.-]+)?$')

# Exception tuple every CLI-shelling helper catches. Pinned in one
# place so all of `_resolve_*_via_cli` / `_collect_*_via_cli` /
# `_parse_*_via_cli` follow the same fallback policy:
#   - OSError: subprocess exec failure, pipe close, broken file handle
#   - ValueError: malformed JSON from CLI stdout
#   - TypeError: defensive — subprocess.run mocked in tests can return
#     MagicMock objects that explode in json.loads (this is the
#     bite the dsym helper hit during TestParseDSYM hardening)
#   - subprocess.CalledProcessError: a side_effect in test mocks that
#     raise rather than return a fake CompletedProcess
_CLI_CATCHALL_EXCEPTIONS = (
    OSError,
    ValueError,
    TypeError,
    subprocess.CalledProcessError,
    # TimeoutExpired: the CLI hung past its `subprocess.run(timeout=...)`
    # cap. Treat as a soft failure so the fallback (in-process Python)
    # path runs — a deadlocked CLI, SIGSTOP'd process, NFS-mounted
    # binary stalling on first run, or an OS sandbox prompt waiting
    # for user interaction would otherwise crash the build.
    subprocess.TimeoutExpired,
)


def detectHostTriple():
    """Map current OS+arch to a Rust target triple the CLI is published for.
    Returns None for unsupported combinations (Linux musl, Windows ARM64, etc.).
    """
    system = platform.system().lower()
    machine = platform.machine().lower()
    is_arm64 = machine in ("arm64", "aarch64")
    is_amd64 = machine in ("x86_64", "amd64")
    if system == "darwin":
        if is_arm64:
            return "aarch64-apple-darwin"
        if is_amd64:
            return "x86_64-apple-darwin"
    elif system == "linux":
        if is_arm64:
            return "aarch64-unknown-linux-gnu"
        if is_amd64:
            return "x86_64-unknown-linux-gnu"
    elif system.startswith("win") or system == "windows":
        if is_amd64:
            return "x86_64-pc-windows-msvc"
    return None


_resolveCli_cache = {}


def resolveCli(cliPath=None, cliVersion=None):
    """Return path to a usable bugsee-cli binary, or None.
    Precedence: explicit cliPath > BUGSEE_CLI_PATH env > auto-download.
    Returning None is a soft failure — caller should fall back / skip.

    Result is memoized by `(cliPath, cliVersion, BUGSEE_CLI_PATH env,
    BUGSEE_CLI_VERSION env)` for the lifetime of the process. The
    plugin invokes this once per CLI helper (8+ times per build) and
    the resolve path includes filesystem walks (cache hit check,
    network-side artefact-existence check) — caching the first
    success/failure avoids the per-call cost. The env vars are part
    of the key because a CI step could (in principle) flip them mid-
    run; the cliPath/cliVersion args ARE typically constant per call
    site but vary across helpers, so include them too.
    """
    cache_key = (
        cliPath,
        cliVersion,
        os.environ.get("BUGSEE_CLI_PATH"),
        os.environ.get("BUGSEE_CLI_VERSION"),
    )
    if cache_key in _resolveCli_cache:
        return _resolveCli_cache[cache_key]
    result = _resolveCli_uncached(cliPath, cliVersion)
    # ONLY cache successful resolutions. A None result means the
    # network was down, the SHA mismatched, or the host was unsupported
    # on THIS call — but a subsequent call (after network comes up,
    # after a retry, after the user installs the binary manually mid-
    # build) may succeed. Caching the None would short-circuit every
    # subsequent helper to the in-process fallback for the rest of
    # the process lifetime.
    if result is not None:
        _resolveCli_cache[cache_key] = result
    return result


def _resolveCli_uncached(cliPath=None, cliVersion=None):
    explicit = cliPath or os.environ.get("BUGSEE_CLI_PATH")
    if explicit:
        if os.path.isfile(explicit) and os.access(explicit, os.X_OK):
            return explicit
        print("Bugsee: --cli-path %s is not an executable file; trying auto-download" % explicit)

    version = cliVersion or os.environ.get("BUGSEE_CLI_VERSION") or BUGSEE_CLI_DEFAULT_VERSION
    # Strict version-string validation BEFORE the value flows into the
    # download URL and the on-disk cache path. Without this, anyone who
    # can set BUGSEE_CLI_VERSION (a malicious CI step, a poisoned .env,
    # a Gemfile post_install) could land the cached binary at e.g.
    # `~/.bugsee/cli/../../malicious_dir/<triple>/bugsee-cli` (path
    # traversal) or redirect the download to a sibling release URL
    # via injected path segments.
    if not _BUGSEE_CLI_VERSION_RE.fullmatch(version):
        print("Bugsee: rejecting BUGSEE_CLI_VERSION=%r — must match X.Y.Z[-prerelease]" % version)
        return None
    triple = detectHostTriple()
    if triple is None:
        print("Bugsee: no published bugsee-cli for host %s/%s; skipping CLI upload" % (
            platform.system(), platform.machine()))
        return None

    cache_root = os.path.expanduser(os.path.join("~/.bugsee/cli", version, triple))
    binary_name = "bugsee-cli.exe" if "windows" in triple else "bugsee-cli"
    cached = os.path.join(cache_root, binary_name)

    if os.path.isfile(cached) and os.access(cached, os.X_OK):
        return cached

    try:
        os.makedirs(cache_root, exist_ok=True)
        _downloadCli(version, triple, cache_root)
    except Exception as e:
        print("Bugsee: failed to download bugsee-cli v%s for %s: %s" % (version, triple, e))
        return None

    if os.path.isfile(cached) and os.access(cached, os.X_OK):
        return cached
    return None


def _downloadCli(version, triple, cacheDir):
    """Fetch tarball + SHA-256 sidecar, verify, extract via system tar."""
    is_windows = "windows" in triple
    ext = "zip" if is_windows else "tar.xz"
    artifact = "bugsee-cli-%s.%s" % (triple, ext)
    url = "%s/v%s/%s" % (BUGSEE_CLI_DOWNLOAD_BASE, version, artifact)
    sha_url = url + ".sha256"

    # Defence-in-depth: refuse to fetch from anywhere but the literal
    # https://download.bugsee.com host. BUGSEE_CLI_DOWNLOAD_BASE is a
    # module global an importer can shadow, and the URL composition
    # accepts any string before the version segment. Pin both the
    # scheme and the host before either urlopen so neither a hostile
    # import nor a typo on the base const can redirect downloads to
    # an attacker-controlled origin. The sidecar verifies tarball
    # integrity, not origin authenticity — those are independent
    # protections that must both hold.
    parsed = urllib.parse.urlsplit(url)
    if parsed.scheme != "https" or parsed.hostname != "download.bugsee.com":
        raise ValueError(
            "Refusing to download bugsee-cli from non-canonical origin %s "
            "(scheme=%s host=%s); set BUGSEE_CLI_DOWNLOAD_BASE back to "
            "https://download.bugsee.com/cli to restore."
            % (url, parsed.scheme, parsed.hostname)
        )

    print("Bugsee: downloading bugsee-cli v%s for %s from %s" % (version, triple, url))

    # SHA-256 sidecar format: `<hex>  <filename>` or `<hex> *<filename>` or just `<hex>`.
    with urllib.request.urlopen(sha_url) as resp:
        expected_sha = resp.read().decode("utf-8").strip().split()[0]

    tarball_path = os.path.join(cacheDir, artifact)
    with urllib.request.urlopen(url) as resp:
        with open(tarball_path, "wb") as f:
            shutil.copyfileobj(resp, f)

    h = hashlib.sha256()
    with open(tarball_path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    actual_sha = h.hexdigest()
    if expected_sha.lower() != actual_sha.lower():
        os.unlink(tarball_path)
        raise IOError("SHA-256 mismatch for %s: expected %s, got %s" % (
            artifact, expected_sha, actual_sha))

    # System `tar` handles tar.xz on macOS/Linux and zip on Windows 10+ (bsdtar).
    # `--strip-components=1` peels the `bugsee-cli-<triple>/` wrapper dir.
    result = subprocess.run(
        ["tar", "-xf", tarball_path, "-C", cacheDir, "--strip-components=1"],
        capture_output=True, text=True)
    if result.returncode != 0:
        raise IOError("tar -xf %s failed (exit %d): %s" % (
            artifact, result.returncode, result.stderr.strip()))

    os.unlink(tarball_path)
    binary_name = "bugsee-cli.exe" if is_windows else "bugsee-cli"
    binary_path = os.path.join(cacheDir, binary_name)
    if not os.path.isfile(binary_path):
        raise IOError("extraction did not produce %s in %s" % (binary_name, cacheDir))
    os.chmod(binary_path, 0o755)
    print("Bugsee: bugsee-cli v%s installed at %s" % (version, binary_path))


def uploadDsymViaCli(cliBinary, dsymPath, appToken, endpoint, version, build):
    """Exec bugsee-cli to upload one .dSYM bundle. Returns True on success."""
    cmd = [
        cliBinary,
        "--endpoint", endpoint,
        "--app-token", appToken,
        "debug-files", "upload",
        "--type", "dsym",
        "--version", version or "",
        "--build", build or "",
        dsymPath,
    ]
    # Stream stderr/stdout straight through so the user sees CLI progress
    # in the same terminal / Xcode log they'd see BugseeAgent output in.
    try:
        result = subprocess.run(cmd, check=False)
        return result.returncode == 0
    except Exception as e:
        print("Bugsee: failed to exec bugsee-cli at %s: %s" % (cliBinary, e))
        return False


def uploadMappingViaCli(cliBinary, mappingPath, appToken, endpoint,
                        version, build, uuid, iconPath=None):
    """Exec bugsee-cli to upload one ProGuard / R8 mapping.txt for
    Android. The fastlane-plugin-bugsee `upload_mapping_to_bugsee`
    action resolves the UUID Ruby-side (either from the Bugsee Gradle
    plugin's BugseeBuildIdResolveTask output, or by Ruby-side
    synthesis matching the SDK's runtime fallback formula) and
    passes it via `uuid`. The CLI's local UUID compute is bypassed.

    Returns True on success.
    """
    cmd = [
        cliBinary,
        "--endpoint", endpoint,
        "--app-token", appToken,
        "debug-files", "upload",
        "--type", "proguard",
        "--version", version or "",
        "--build", build or "",
        "--uuid", uuid or "",
    ]
    if iconPath:
        cmd.extend(["--icon", iconPath])
    cmd.append(mappingPath)
    try:
        result = subprocess.run(cmd, check=False)
        return result.returncode == 0
    except Exception as e:
        print("Bugsee: failed to exec bugsee-cli at %s: %s" % (cliBinary, e))
        return False


# ──────────────────────────────────────────────────────────────────
# Build dependencies collection (parallel to the Android Gradle
# plugin's `DependencyCollector` — wire format must stay in lockstep
# with `BugseeBuildDependenciesPipelineRecipe` consumed by the
# Bugsee worker / appserver / viewer stack).
#
# Sources scanned, in order:
#   1. CocoaPods         — Podfile.lock (full resolved tree with
#                          parent → child edges)
#   2. Swift Package Mgr — Package.resolved (flat list, no graph)
#   3. Carthage          — Cartfile.resolved (flat list, no graph)
#   4. Vendored frames   — `otool -L` on the linked product binary,
#                          filtered to @rpath / @executable_path
#                          entries (system frameworks excluded)
#
# Output: same shape the Android plugin emits — a JSON dictionary
# carrying `schema_version: 1` and a `dependencies` array of
# objects with keys: `id`, `group`, `name`, `version`, `direct`,
# `scope`, `type`, `parents`. iOS-specific mapping notes:
#
#   - `group` is the empty string for every source iOS deps come
#     from (Pods / SPM packages / Carthage / vendored frameworks
#     don't carry the Maven group:name:version triple).
#   - `id` is `"<type>:<group>:<name>"` — three colons total for
#     iOS rows because `group` is empty, matching the format the
#     viewer's identityOf and the worker's _identity functions
#     produce. Subspecs (e.g. "Braintree/Card") keep the slash
#     in `name`.
#   - `type` is one of `library` (Pods + SPM + Carthage) or
#     `file` (vendored frameworks discovered via otool). No
#     `project` rows from iOS for now — local SPM packages are
#     emitted as library-type with the package name; the path
#     distinction isn't surfaced.
#   - `scope` is left unset by default. CocoaPods has a
#     `:configuration` qualifier on `pod` directives but that's a
#     Podfile-time concept the lockfile doesn't surface.
# ──────────────────────────────────────────────────────────────────

# Wire-format schema version. Must equal the Android plugin's
# `DependencyPayloadSerializer.SCHEMA_VERSION` and be in the worker's
# `_SUPPORTED_SCHEMA_VERSIONS` set; any bump on either side requires
# a parallel bump here.
DEPENDENCIES_SCHEMA_VERSION = 1

# Maximum number of entries we keep before truncating — same cap
# the Android plugin uses (5000). The summary's `truncated` flag
# surfaces when the cap kicks in, and the worker uses it to gate
# diffability (truncated builds can't be diffed against each
# other since the lists aren't apples-to-apples).
DEPENDENCIES_MAX_COUNT = 5000


def _make_dep_id(dep_type, group, name):
    """Canonical identity string `"<type>:<group>:<name>"`. The
    triple must stay byte-for-byte identical with the Android
    plugin's `DependencyEntry.makeId` and the worker's
    `_make_identity` so cross-platform diff matching works."""
    return "%s:%s:%s" % (dep_type, group, name)


def _strip_pod_version_paren(s):
    """Strip the ` (version)` or ` (~> constraint)` suffix from a
    CocoaPods reference. Returns just the bare name, e.g.
    `"Braintree/Card (= 5.26.0)"` -> `"Braintree/Card"`.
    Used for both DEPENDENCIES section entries and child references
    inside the PODS section — both wear the same version-paren
    suffix and we always want the underlying name as the lookup key.
    """
    paren_pos = s.find('(')
    if paren_pos == -1:
        return s.strip()
    return s[:paren_pos].strip()


def _parse_podfile_lock(path):
    """Parse a CocoaPods `Podfile.lock` and return a list of dep
    entries with parent edges.

    Strategy:
      1. Walk the PODS: section line-by-line tracking indent depth.
         A 2-space-indent line is a top-level pod declaration of
         shape `- Name (Version):` (the trailing colon is optional —
         pods with no transitive children skip the colon).
         A 4-space-indent line is a child of the last top-level pod
         seen, of shape `- Name [(constraint)]`.
      2. Walk the DEPENDENCIES: section in the same indent style,
         collecting the bare name (no constraint) of every entry
         the user declared directly in their Podfile.
      3. Emit one entry per top-level pod. `direct` is true iff
         the pod (or a subspec whose base name matches) appears in
         the DEPENDENCIES set. `parents` is the list of `id`s of
         pods that referenced this one as a child — built by
         reverse-walking the children map.

    The format is YAML-ish but we don't pull in PyYAML — single-file
    distribution constraint, and the lockfile shape is rigid enough
    that a hand-rolled parser is robust.
    """
    if not path or not os.path.isfile(path):
        return []

    with open(path, 'r', encoding='utf-8') as f:
        lines = f.read().splitlines()

    # Split into sections by the top-level uppercase headers
    # `PODS:`, `DEPENDENCIES:`, `SPEC REPOS:`, etc. Section start is
    # a line at column 0 ending in ':' (we ignore everything past
    # the PODS / DEPENDENCIES sections — SPEC CHECKSUMS, etc.).
    pods_lines = []
    deps_lines = []
    current = None
    for line in lines:
        if re.match(r'^[A-Z][A-Z _]+:\s*$', line):
            header = line.rstrip(': ').strip()
            if header == 'PODS':
                current = pods_lines
            elif header == 'DEPENDENCIES':
                current = deps_lines
            else:
                current = None
            continue
        if current is not None:
            current.append(line)

    # PODS section parse: top-level pods and their immediate
    # children. We don't recurse — CocoaPods's lockfile is flat
    # past depth 2 (children are pod refs, not nested declarations).
    pods = {}          # name -> {"version": str, "children": [str]}
    current_pod = None
    pod_line_re = re.compile(r'^  - (.+?)(?::?)$')
    child_line_re = re.compile(r'^    - (.+?)$')
    name_version_re = re.compile(r'^(.+?)\s+\(([^)]+)\)\s*$')
    for line in pods_lines:
        if not line.strip():
            continue
        m = child_line_re.match(line)
        if m and current_pod is not None:
            child_ref = _strip_pod_version_paren(m.group(1))
            pods[current_pod]["children"].append(child_ref)
            continue
        m = pod_line_re.match(line)
        if m:
            body = m.group(1)
            nv = name_version_re.match(body)
            if nv:
                name = nv.group(1).strip()
                version = nv.group(2).strip()
            else:
                # Pod with no version paren — defensive; shouldn't
                # happen in a well-formed lockfile but we don't
                # crash on it.
                name = body.strip()
                version = None
            pods[name] = {"version": version, "children": []}
            current_pod = name

    # DEPENDENCIES section parse: just the bare names of pods the
    # user declared directly in their Podfile.
    direct_names = set()
    dep_line_re = re.compile(r'^  - (.+?)$')
    for line in deps_lines:
        if not line.strip():
            continue
        m = dep_line_re.match(line)
        if m:
            direct_names.add(_strip_pod_version_paren(m.group(1)))

    # Reverse-walk the children map to build the parents lookup:
    # for each child reference, the owning top-level pod is a
    # parent. A child reference can include a subspec slash (e.g.
    # `Braintree/Card`) — we record the parent against the exact
    # referenced name, so subspecs end up with parents pointing at
    # the pods that pulled them in (typically the parent pod and
    # any cross-pod users).
    parents_by_name = {}
    for owner_name, info in pods.items():
        owner_id = _make_dep_id("library", "", owner_name)
        for child_ref in info["children"]:
            parents_by_name.setdefault(child_ref, []).append(owner_id)

    # Emit one entry per top-level pod. A pod is "direct" iff its
    # EXACT name appears in DEPENDENCIES. CocoaPods writes subspecs
    # into DEPENDENCIES verbatim when the user named them
    # explicitly (`pod 'Foo', :subspecs => ['Bar']` → `Foo/Bar`
    # appears in DEPENDENCIES). When the user writes `pod 'Foo'`
    # against an umbrella pod, only `Foo` is in DEPENDENCIES —
    # subspecs are pulled in transitively as children of the
    # umbrella, which is exactly how the user intended.
    entries = []
    for name, info in pods.items():
        is_direct = name in direct_names
        entries.append({
            "id":      _make_dep_id("library", "", name),
            "group":   "",
            "name":    name,
            "version": info["version"],
            "direct":  is_direct,
            "scope":   None,
            "type":    "library",
            "parents": list(parents_by_name.get(name, [])),
        })

    return entries


def _parse_package_resolved(path):
    """Parse Swift Package Manager's `Package.resolved` (JSON).

    Two formats exist in the wild:
      - Xcode-managed: `{"object": {"pins": [...]}, "version": 1|2}`
      - SPM CLI v2:    `{"pins": [...], "version": 2}` (Xcode 14+
        and `swift package` write this at the project root)

    Both carry the same per-pin information: a package identity
    (kind/location/name) plus a resolved version pin. The resolved
    file does NOT carry the dependency graph — only the locked
    list — so every entry comes out as `direct=true` with no
    parents. Tree-view rendering on the viewer reduces to a flat
    list for SPM-only builds, which is correct: we don't have the
    information to do better.
    """
    if not path or not os.path.isfile(path):
        return []

    try:
        with open(path, 'r', encoding='utf-8') as f:
            data = json.load(f)
    except (OSError, ValueError):
        return []

    pins = None
    if isinstance(data, dict):
        if isinstance(data.get('pins'), list):
            pins = data['pins']
        elif isinstance(data.get('object'), dict) \
                and isinstance(data['object'].get('pins'), list):
            pins = data['object']['pins']
    if not pins:
        return []

    entries = []
    for pin in pins:
        if not isinstance(pin, dict):
            continue
        # Identity field name differs by format:
        #   - new format uses `identity` (lowercase package name)
        #   - legacy format uses `package` (capitalised display name)
        # Prefer `identity` when present so the id is stable across
        # Xcode versions writing the same package set.
        name = pin.get('identity') or pin.get('package')
        if not name:
            continue
        version = None
        state = pin.get('state') or {}
        if isinstance(state, dict):
            # `version` for tagged pins; `branch` for branch
            # tracking; `revision` for revision-locked pins. Prefer
            # the most specific human-readable value.
            version = state.get('version') or state.get('branch') or state.get('revision')
        # SPM URL — `location` is the v2/v3 key, `repositoryURL`
        # the v1 key. Load-bearing for OSV vuln lookups (OSV's
        # SwiftURL ecosystem keys off this URL). The Rust CLI
        # emits this field too (bugsee-cli/src/cli/ios_deps.rs's
        # `parse_package_resolved`); the in-process Python
        # fallback must match or the wire-shape silently diverges
        # depending on which path produced the payload.
        url = pin.get('location') or pin.get('repositoryURL')
        entry = {
            "id":      _make_dep_id("library", "", name),
            "group":   "",
            "name":    name,
            "version": version,
            "direct":  True,
            "scope":   None,
            "type":    "library",
            "parents": [],
        }
        if url:
            entry["url"] = url
        entries.append(entry)
    return entries


def _parse_cartfile_resolved(path):
    """Parse a Carthage `Cartfile.resolved`. Each line has the
    shape: `<source> "<repo>" "<version>"`. Examples:

      github "ReactiveCocoa/ReactiveCocoa" "v2.3.1"
      git "https://example.com/private.git" "1.0.0"
      binary "https://example.com/MyBin.json" "1.0.0"

    Emit one library entry per line. No graph info, so direct=true
    and parents=[]. The repo path (e.g. `ReactiveCocoa/ReactiveCocoa`)
    becomes the name verbatim — surfacing the slash keeps the
    namespacing visible in the dashboard.
    """
    if not path or not os.path.isfile(path):
        return []

    try:
        with open(path, 'r', encoding='utf-8') as f:
            lines = f.read().splitlines()
    except OSError:
        return []

    entries = []
    # `<source> "repo" "version"` — tolerate single-quoted values
    # too (Carthage's parser does).
    line_re = re.compile(r'^\s*(\S+)\s+["\']([^"\']+)["\']\s+["\']([^"\']+)["\']\s*$')
    for line in lines:
        if not line.strip() or line.strip().startswith('#'):
            continue
        m = line_re.match(line)
        if not m:
            continue
        name = m.group(2)
        version = m.group(3)
        entries.append({
            "id":      _make_dep_id("library", "", name),
            "group":   "",
            "name":    name,
            "version": version,
            "direct":  True,
            "scope":   None,
            "type":    "library",
            "parents": [],
        })
    return entries


# Mach-O load paths emitted by `otool -L` that point at OS-owned
# frameworks. Stripped from the vendored-framework scan since they
# aren't user dependencies and would just bloat the list.
_SYSTEM_DYLIB_PREFIXES = (
    '/usr/lib/',
    '/System/Library/',
    '/Library/Frameworks/',
)


def _parse_vendored_frameworks(binary_path):
    """Run `otool -L` on the linked product binary and return a
    list of dep entries for embedded / vendored frameworks. Lines
    whose load path starts with `@rpath/`, `@executable_path/`, or
    `@loader_path/` are the embedded frameworks shipped inside
    the .app bundle; everything else is either the OS or a Swift
    toolchain dylib — neither is a user dependency.

    Each entry is `type="file"`, direct=true, no parents. The
    `name` is the framework's basename (e.g. `Bugsee.framework`)
    rather than the full @rpath path — the user-recognisable form.
    """
    if not binary_path or not os.path.isfile(binary_path):
        return []

    try:
        out = subprocess.run(
            ['/usr/bin/otool', '-L', binary_path],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []

    seen = set()
    entries = []
    # Sample line: `\t@rpath/Bugsee.framework/Bugsee (compatibility version 1.0.0, current version 1.0.0)`
    line_re = re.compile(r'^\s*([^\s]+)\s+\(compatibility version')
    for raw in out.splitlines():
        m = line_re.match(raw)
        if not m:
            continue
        load_path = m.group(1)
        if load_path.startswith(_SYSTEM_DYLIB_PREFIXES):
            continue
        if not (load_path.startswith('@rpath/')
                or load_path.startswith('@executable_path/')
                or load_path.startswith('@loader_path/')):
            continue
        # Extract the framework name: the `.framework/X` suffix
        # carries Mach-O's binary slice name; the directory above
        # it is the user-facing framework. Falls back to the
        # basename if the path doesn't carry a `.framework/` token.
        framework_match = re.search(r'/([^/]+\.framework)/', load_path)
        if framework_match:
            name = framework_match.group(1)
        else:
            name = os.path.basename(load_path)
        if name in seen:
            continue
        seen.add(name)
        entries.append({
            "id":      _make_dep_id("file", "", name),
            "group":   "",
            "name":    name,
            "version": None,
            "direct":  True,
            "scope":   None,
            "type":    "file",
            "parents": [],
        })
    return entries


def _merge_dep_entries(*sources):
    """Combine multiple dep-entry lists into one. Deduplication
    is field-wise — first-seen entry survives, but later sources
    can graft on missing `url` / `version` / `parents` and OR-merge
    the `direct` flag.

    Why field-wise instead of pure first-source-wins: the parsers
    populate these fields asymmetrically. CocoaPods walks the PODS
    graph and emits `direct: false` + `parents: ["<umbrella>"]`
    for transitive subspecs; SPM emits `direct: true` +
    `parents: []` because `Package.resolved` only records resolved
    pins, not the dependency graph; SPM ALSO carries the upstream
    `url` (load-bearing for OSV vuln lookups). Wholesale-replacing
    the existing record on url-preference would wipe the CocoaPods
    graph evidence; ignoring url-bearing later sources would lose
    the upstream URL. Mirrors the Rust CLI's `merge_dep_entries`
    in `bugsee-cli/src/cli/ios_deps.rs`.

    Returns a `(entries, truncated)` pair, capped at
    [DEPENDENCIES_MAX_COUNT]. The truncated flag drives the
    summary's same-name field and ultimately the worker's
    compatibility check (truncated lists aren't diff-comparable).
    """
    by_id = {}
    insertion_order = []
    for source in sources:
        for entry in source:
            eid = entry["id"]
            if eid not in by_id:
                # Defensive copy so later same-id mutations don't
                # bleed back into the caller's source list.
                by_id[eid] = dict(entry)
                insertion_order.append(eid)
                continue
            prev = by_id[eid]
            # url: copy from incoming when previous has none.
            if not prev.get("url") and entry.get("url"):
                prev["url"] = entry["url"]
            # direct: OR-merge — any source reaching the package
            # directly is authoritative.
            if entry.get("direct"):
                prev["direct"] = True
            # version: fill in when previous has none.
            if prev.get("version") in (None, "") and entry.get("version"):
                prev["version"] = entry["version"]
            # parents: backfill when previous is empty. The first
            # non-empty parents list wins so a follow-on source
            # with `parents: []` can't wipe the graph evidence.
            if not prev.get("parents") and entry.get("parents"):
                prev["parents"] = list(entry["parents"])

    deduped = [by_id[i] for i in insertion_order]
    truncated = False
    if len(deduped) > DEPENDENCIES_MAX_COUNT:
        truncated = True
        # Direct-prefer truncation: keep direct entries first.
        # Stable sort preserves insertion order within each group.
        deduped.sort(key=lambda e: 0 if e.get("direct") else 1)
        deduped = deduped[:DEPENDENCIES_MAX_COUNT]

    # Self-consistency pass: filter parents pointing at IDs that
    # didn't make it into the emitted set (truncation eviction
    # OR a malformed source listing a phantom parent). Same posture
    # as the Android plugin's post-truncation cleanup.
    kept = {e["id"] for e in deduped}
    for e in deduped:
        if e.get("parents"):
            e["parents"] = [p for p in e["parents"] if p in kept]
    return deduped, truncated


def _build_dependencies_payload(entries, truncated, scope_label,
                                include_selected_reason=False,
                                max_count=DEPENDENCIES_MAX_COUNT,
                                clock=None):
    """Build the JSON-serialisable summary + blob pair. Shape
    mirrors what the Android plugin produces (see
    `DependencyPayloadSerializer.summaryJson` / `entriesJson`).

    Returns a tuple `(summary_dict, blob_dict)`:
      - `summary_dict` is the scalar summary sent inline on the
        build registration POST body (under
        `dependencies_summary`).
      - `blob_dict` is the per-entry list serialised as JSON and
        gzipped before PUT.
    """
    clock = clock or (lambda: int(time.time() * 1000))
    total = len(entries)
    direct = sum(1 for e in entries if e["direct"])
    transitive = total - direct
    by_type = {"library": 0, "project": 0, "file": 0}
    for e in entries:
        t = e["type"]
        if t in by_type:
            by_type[t] += 1

    # ISO-8601 UTC with the trailing `Z` form — matches the
    # Android plugin's `isoUtc` helper so the appserver's
    # `new Date(collected_at)` parses identically.
    epoch_ms = clock()
    iso_utc = time.strftime('%Y-%m-%dT%H:%M:%SZ',
                            time.gmtime(epoch_ms / 1000))

    summary = {
        "total":      total,
        "direct":     direct,
        "transitive": transitive,
        "by_type":    by_type,
        "truncated":  truncated,
        "collected_at": iso_utc,
        "collection_config": {
            "scope":                   scope_label,
            "include_selected_reason": include_selected_reason,
            "max_count":               max_count,
        },
    }

    # Per-entry blob. Omit `version` / `scope` when None, omit
    # empty `parents` lists — same wire posture the Android
    # serializer takes. Keeps the gzipped payload small for the
    # common case (most pods don't have transitive children).
    serialised = []
    for e in entries:
        item = {
            "id":     e["id"],
            "group":  e["group"],
            "name":   e["name"],
            "direct": e["direct"],
            "type":   e["type"],
        }
        if e.get("version"):
            item["version"] = e["version"]
        if e.get("scope"):
            item["scope"] = e["scope"]
        if e.get("parents"):
            item["parents"] = list(e["parents"])
        # SPM `url` (load-bearing for OSV's SwiftURL vuln lookups).
        # Mirrors the Rust `DepEntry::url` field's
        # `#[serde(skip_serializing_if = "Option::is_none")]`. Without
        # this, fastlane Python-fallback uploads would emit
        # url-less blobs even when the CLI populated url, silently
        # degrading vuln-scan coverage vs the SDK-side blob shape.
        if e.get("url"):
            item["url"] = e["url"]
        serialised.append(item)

    blob = {
        "schema_version": DEPENDENCIES_SCHEMA_VERSION,
        "dependencies":   serialised,
    }
    return summary, blob


def _gzip_json_bytes(obj):
    """Serialise `obj` to compact JSON and return gzipped bytes.
    The blob is uploaded to a presigned S3 URL with
    `Content-Encoding: gzip` on the worker side; the producer
    PUT carries `application/octet-stream` (matching the Android
    plugin's signing posture)."""
    raw = json.dumps(obj, separators=(',', ':')).encode('utf-8')
    return gzip.compress(raw, compresslevel=9)


# ──────────────────────────────────────────────────────────────────
# Build environment metadata (machine label, VCS, Xcode version)
#
# Ported from the SDK's tools.bundle/BugseeAgent. The wire shape
# matches the Android Gradle plugin's `BuildMachineResolver` and
# `VcsMetadataResolver` so a single build record can compare iOS
# and Android runs from the same CI runner.
#
# The appserver's `sanitizeVcs` / `sanitizeBuildMetadata`
# (appserver/code/components/app/builds/modules/build.vcs-helper.js)
# accepts these fields verbatim; the dashboard's build view reads
# `vcs.branch` / `vcs.commit_sha` / `vcs.pr_number` directly.
# ──────────────────────────────────────────────────────────────────

def _env_truthy(value):
    """True when an env-var-style value is a conventional "on" token.
    Matches the set used by the Android Gradle plugin (`"1"`, `"true"`,
    `"yes"`, `"on"`, case-insensitive) so one CI config snippet
    can enable a feature on both platforms."""
    return (value or '').strip().lower() in ('1', 'true', 'yes', 'on')


def _set_if_present(out, key, value):
    """Only write `key` to `out` when `value` is a non-empty string.
    Keeps the JSON payload clean — the back-end distinguishes
    "unknown" from "known empty" by field presence."""
    if value and str(value).strip():
        out[key] = str(value).strip()


def _local_hostname():
    """Short hostname or None. `socket.gethostname()` is the standard
    cross-platform lookup; it may throw on sandboxed hosts, hence
    the broad except."""
    try:
        host = socket.gethostname()
        return host if host else None
    except Exception:
        return None


def _resolve_machine_label_via_cli():
    """Shell to `bugsee-cli build-env machine-label` and return the
    trimmed stdout. Option-C target."""
    cli_path_opt = None
    cli_version_opt = None
    try:
        cli_path_opt = getattr(options, 'cli_path', None)
        cli_version_opt = getattr(options, 'cli_version', None)
    except NameError:
        pass
    cli = resolveCli(cli_path_opt, cli_version_opt)
    if not cli:
        return None
    try:
        result = subprocess.run(
            [cli, "build-env", "machine-label"],
            capture_output=True, text=True, timeout=10, check=False,
        )
        if result.returncode != 0:
            return None
        out = (result.stdout or "").strip()
        return out if out else None
    except _CLI_CATCHALL_EXCEPTIONS:
        return None


def resolve_machine_label():
    """Returns a `<provider>[:<detail>]` label describing where the
    build ran — mirrors the cascade in the Android plugin's
    `BuildMachineResolver` so the front-end can group iOS + Android
    builds from the same CI runner.

    Prefers `bugsee-cli build-env machine-label` (single cross-
    language source of truth). Falls back to the in-process
    Python implementation below — pure env-based detection; no
    shelling out.

    First positive provider signal wins. Falls back to the local
    hostname when nothing matches AND hostname lookup succeeds.
    Returns None as last resort (sandboxed / networkless hosts).
    """
    via_cli = _resolve_machine_label_via_cli()
    if via_cli is not None:
        return via_cli

    env = os.environ

    def with_detail(prefix, detail):
        detail = (detail or '').strip()
        return '%s:%s' % (prefix, detail) if detail else prefix

    if _env_truthy(env.get('GITHUB_ACTIONS')):
        return with_detail('github-actions', env.get('RUNNER_NAME'))
    if _env_truthy(env.get('GITLAB_CI')):
        detail = ((env.get('CI_RUNNER_DESCRIPTION') or '').strip()
                  or (env.get('CI_RUNNER_ID') or '').strip())
        return with_detail('gitlab-ci', detail)
    if (env.get('JENKINS_URL') or '').strip():
        return with_detail('jenkins', env.get('NODE_NAME'))
    if _env_truthy(env.get('CIRCLECI')):
        return with_detail('circleci', env.get('CIRCLE_NODE_INDEX'))
    if _env_truthy(env.get('BITRISE_IO')):
        return with_detail('bitrise', env.get('BITRISE_APP_SLUG'))
    if (env.get('TEAMCITY_VERSION') or '').strip():
        agent_name = ((env.get('AGENT_NAME') or '').strip()
                      or (env.get('agent.name') or '').strip())
        return with_detail('teamcity', agent_name)
    # Xcode Cloud — Apple's own CI. `CI_WORKFLOW` is the canonical
    # presence signal; `CI_XCODEBUILD_ACTION` adds action context
    # (build / archive / test) when available.
    if ((env.get('CI_WORKFLOW') or '').strip()
            or _env_truthy(env.get('CI_XCODE_CLOUD'))):
        detail = ((env.get('CI_WORKFLOW') or '').strip()
                  or (env.get('CI_XCODEBUILD_ACTION') or '').strip())
        return with_detail('xcode-cloud', detail)
    if _env_truthy(env.get('CI')):
        host = ((env.get('HOSTNAME') or '').strip()
                or _local_hostname() or '')
        return with_detail('ci', host)

    return _local_hostname()


def _run_git(working_dir, git_args):
    try:
        result = subprocess.run(
            ['/usr/bin/env', 'git'] + list(git_args),
            cwd=working_dir,
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return None
        return (result.stdout or '').strip() or None
    except Exception:
        return None


def _resolve_git_fallback(working_dir):
    """Shell out to `git` for the basics. Returns {} if not a git
    working tree, or if `git` isn't on PATH (rare on dev macs, but
    possible in stripped-down CI containers)."""
    if not working_dir or not os.path.isdir(working_dir):
        return {}
    out = {}
    commit = _run_git(working_dir, ['rev-parse', 'HEAD'])
    if commit:
        out['commit_sha'] = commit
    branch = _run_git(working_dir, ['rev-parse', '--abbrev-ref', 'HEAD'])
    # Detached HEADs show up as "HEAD" — not a meaningful branch name.
    if branch and branch != 'HEAD':
        out['branch'] = branch
    return out


def _resolve_vcs_metadata_via_cli(cli_binary, working_dir):
    """Shell to `bugsee-cli vcs-metadata` and parse its JSON output.

    Part of the Option-C migration that moved VCS resolution to the
    Rust CLI as the single canonical implementation. The Python
    fallback below is preserved for the case where the CLI isn't
    available (older CLI versions that don't have the subcommand,
    a stripped-down env without auto-download, etc.).

    Returns the parsed dict on success, or None on any failure
    (subprocess error, non-zero exit, malformed JSON). The caller
    falls back to the Python implementation on None.
    """
    if not cli_binary:
        return None
    try:
        result = subprocess.run(
            [cli_binary, "vcs-metadata", "--working-dir", working_dir or "."],
            capture_output=True, text=True, timeout=10, check=False,
        )
        if result.returncode != 0:
            return None
        out = (result.stdout or "").strip()
        if not out:
            return None
        return json.loads(out)
    except _CLI_CATCHALL_EXCEPTIONS:
        return None


def resolve_vcs_metadata(working_dir):
    """Returns a dict shaped for the upload JSON's nested `vcs`
    sub-object. Matches what the Android Gradle plugin emits so the
    back-end persists both identically. Keys (any / all may be
    absent):

        commit_sha, base_sha, branch, base_branch, pr_number,
        provider, repo

    Resolution order — first provider with a positive signal wins:
      1. GitHub Actions env (push + pull_request events).
      2. GitLab CI env (push + merge_request events).
      3. Bitbucket Pipelines env.
      4. Git fallback — shell out to `git` in `working_dir` when
         none of the CI providers matched. Lets local dev archives
         still carry `commit_sha` / `branch` without needing CI
         context.

    Implementation: prefers the Rust `bugsee-cli vcs-metadata`
    subcommand (the single cross-language source of truth, ported
    from this Python function — see
    `bugsee-cli/src/cli/vcs_metadata.rs`). Falls back to the
    in-process Python implementation below when the CLI isn't
    available so cold-start environments without the CLI cache
    still produce a usable result.
    """
    # Try the Rust CLI first — same algorithm, in the canonical
    # cross-language implementation. `options` is set by main() in
    # production but unset at import time (tests load the agent as
    # a module without ever invoking main()); the NameError catch
    # lets the resolver still invoke resolveCli with defaults so
    # the mock-based unit tests can exercise the CLI path.
    cli_path_opt = None
    cli_version_opt = None
    try:
        cli_path_opt = getattr(options, 'cli_path', None)
        cli_version_opt = getattr(options, 'cli_version', None)
    except NameError:
        pass
    cli = resolveCli(cli_path_opt, cli_version_opt)
    if cli:
        via_cli = _resolve_vcs_metadata_via_cli(cli, working_dir)
        if via_cli is not None:
            return via_cli

    env = os.environ

    # GitHub Actions ----------------------------------------------
    if _env_truthy(env.get('GITHUB_ACTIONS')):
        out = {'provider': 'github'}
        _set_if_present(out, 'commit_sha', env.get('GITHUB_SHA'))
        _set_if_present(out, 'repo',       env.get('GITHUB_REPOSITORY'))
        if (env.get('GITHUB_EVENT_NAME') or '') == 'pull_request':
            _set_if_present(out, 'branch',      env.get('GITHUB_HEAD_REF'))
            _set_if_present(out, 'base_branch', env.get('GITHUB_BASE_REF'))
            m = re.search(r'refs/pull/(\d+)/', env.get('GITHUB_REF') or '')
            if m:
                out['pr_number'] = int(m.group(1))
        else:
            # Push event: GITHUB_REF carries `refs/heads/<branch>` for
            # a branch push, `refs/tags/<tag>` for a tag push. Only
            # emit `branch` when the ref is actually a head ref. The
            # historical `.replace('refs/heads/', '', 1)` returned the
            # raw `refs/tags/v1.0.0` ref on tag pushes, which then
            # landed in the dashboard's branch column verbatim. Match
            # the Android Gradle plugin's canonical Kotlin resolver
            # (`removePrefix.takeIf { it != ref }`) and the Rust CLI
            # (bugsee-cli@cf1325f).
            ref = (env.get('GITHUB_REF') or '')
            if ref.startswith('refs/heads/'):
                _set_if_present(out, 'branch', ref[len('refs/heads/'):])
        return out

    # GitLab CI ---------------------------------------------------
    if _env_truthy(env.get('GITLAB_CI')):
        out = {'provider': 'gitlab'}
        _set_if_present(out, 'commit_sha', env.get('CI_COMMIT_SHA'))
        _set_if_present(out, 'repo',       env.get('CI_PROJECT_PATH'))
        # Merge-request pipelines expose different branch variables
        # than push pipelines. `CI_MERGE_REQUEST_IID` is the MR
        # number (the `_ID` variant is a global DB id and unusable
        # as a PR reference).
        if (env.get('CI_MERGE_REQUEST_IID') or '').strip():
            _set_if_present(out, 'branch',
                            env.get('CI_MERGE_REQUEST_SOURCE_BRANCH_NAME'))
            _set_if_present(out, 'base_branch',
                            env.get('CI_MERGE_REQUEST_TARGET_BRANCH_NAME'))
            try:
                out['pr_number'] = int(env.get('CI_MERGE_REQUEST_IID'))
            except (TypeError, ValueError):
                pass
        else:
            # Branch vs tag pipeline distinction. GitLab CI sets:
            #   - CI_COMMIT_BRANCH on branch pipelines (not tag).
            #   - CI_COMMIT_TAG on tag pipelines (not branch).
            #   - CI_COMMIT_REF_NAME is ALWAYS set; on a tag pipeline
            #     it equals the tag name. Without the gate, tag
            #     pipelines leaked the tag into the branch column.
            # Prefer CI_COMMIT_BRANCH; if absent and CI_COMMIT_TAG is
            # set, leave branch absent. Fall back to CI_COMMIT_REF_NAME
            # only for legacy GitLab (pre-12.6) that lacked the
            # specific markers.
            if (env.get('CI_COMMIT_BRANCH') or '').strip():
                _set_if_present(out, 'branch', env.get('CI_COMMIT_BRANCH'))
            elif (env.get('CI_COMMIT_TAG') or '').strip():
                pass  # tag pipeline — branch stays absent
            else:
                _set_if_present(out, 'branch', env.get('CI_COMMIT_REF_NAME'))
        return out

    # Bitbucket Pipelines -----------------------------------------
    if (env.get('BITBUCKET_BUILD_NUMBER') or '').strip():
        out = {'provider': 'bitbucket'}
        _set_if_present(out, 'commit_sha', env.get('BITBUCKET_COMMIT'))
        _set_if_present(out, 'repo',
                        env.get('BITBUCKET_REPO_FULL_NAME')
                        or env.get('BITBUCKET_REPO_SLUG'))
        _set_if_present(out, 'branch',     env.get('BITBUCKET_BRANCH'))
        if (env.get('BITBUCKET_PR_ID') or '').strip():
            _set_if_present(out, 'base_branch',
                            env.get('BITBUCKET_PR_DESTINATION_BRANCH'))
            try:
                out['pr_number'] = int(env.get('BITBUCKET_PR_ID'))
            except (TypeError, ValueError):
                pass
        return out

    # Git fallback ------------------------------------------------
    # Covers local archives + any CI provider we don't specifically
    # recognise. Missing `provider` / `repo` is fine — the server
    # accepts partial payloads.
    return _resolve_git_fallback(working_dir)


def _resolve_xcode_version_via_cli():
    """Shell to `bugsee-cli build-env xcode-version` and return the
    trimmed stdout. Option-C migration target — the Rust CLI owns
    the canonical resolver. Returns None on CLI absence /
    non-zero exit / empty output (the Python fallback below
    handles those cases)."""
    cli_path_opt = None
    cli_version_opt = None
    try:
        cli_path_opt = getattr(options, 'cli_path', None)
        cli_version_opt = getattr(options, 'cli_version', None)
    except NameError:
        pass
    cli = resolveCli(cli_path_opt, cli_version_opt)
    if not cli:
        return None
    try:
        result = subprocess.run(
            [cli, "build-env", "xcode-version"],
